---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nikki Cates | Strategic Transformations</title>
    <meta name="description" content="Structural Burnout Strategist & Leadership Architecture" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen font-sans antialiased">
    <!-- Sticky Navigation with Logos -->
    <nav class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-md border-b border-zinc-800">
      <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
        <!-- Logo Area -->
        <a href="/" class="flex items-center gap-4">
          <img src="/assets/st-logo.png" alt="Strategic Transformations" class="h-10 w-auto" onerror="this.style.display='none'">
          <img src="/assets/uri-logo.png" alt="Unbothered Resistance International" class="h-8 w-auto" onerror="this.style.display='none'">
          <span class="text-2xl font-bold tracking-tighter">Nikki Cates</span>
        </a>

        <div class="hidden md:flex items-center gap-8 text-sm font-medium">
          <a href="/structural-burnout" class="hover:text-teal-400 transition">Structural Burnout</a>
          <a href="/structural-burnout/services" class="hover:text-teal-400 transition">Services</a>
          <a href="/structural-burnout/nexus" class="hover:text-teal-400 transition">Nexus</a>
        </div>

        <a href="/structural-burnout/briefing" 
           class="px-6 py-2.5 text-sm border border-teal-400 hover:bg-teal-400 hover:text-zinc-950 rounded-full transition">
          Start Diagnostic
        </a>
      </div>
    </nav>

    <slot />
  </body>
</html>