---
import Layout from '../../layouts/Layout.astro';

const calendarUrl = 'https://calendar.app.google/e8ErMQqHhmnHn1hk6';
---

<Layout
  title="The Frictionless Manager Bootcamp | Strategic Transformations"
  description="A 2-day strategic bootcamp for organizations helping middle managers lead through AI adoption without structural breakdown. Diagnose the friction before it costs you your best people."
  section="st"
  accentColor="teal"
>

  <!-- ─── HERO ─────────────────────────────────────── -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-[#0f172a]"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 70% at 65% 45%, rgba(13,148,136,0.09) 0%, transparent 65%), radial-gradient(ellipse 50% 60% at 5% 85%, rgba(15,76,122,0.1) 0%, transparent 55%);"></div>
    <div class="absolute left-0 top-0 bottom-0 w-[3px]" style="background: linear-gradient(to bottom, transparent 5%, #0d9488 25%, #0d9488 75%, transparent 95%);"></div>

    <div class="container-wide relative z-10 py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

        <!-- Left: Core message -->
        <div class="lg:col-span-7 text-center lg:text-left">
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3 mb-6">
            <span class="st-tag inline-flex">Strategic Transformations</span>
            <span class="text-[10px] uppercase tracking-[0.24em] text-muted border border-border rounded-full px-3 py-1">
              B2O · Organizations &amp; Leadership Teams
            </span>
          </div>
          <h1 class="font-heading font-bold text-light leading-[1.06] mb-6 animate-on-scroll" style="font-size: clamp(2.4rem, 5.5vw, 4.2rem);">
            The Frictionless<br/>
            <span class="text-teal-DEFAULT">Manager Bootcamp</span>
          </h1>
          <p class="font-body text-xl text-light leading-relaxed mb-4 max-w-2xl mx-auto lg:mx-0 animate-on-scroll" style="animation-delay:0.08s">
            Your managers are not failing. Your structure is.
          </p>
          <p class="font-body text-lg text-muted leading-relaxed mb-4 max-w-2xl mx-auto lg:mx-0 animate-on-scroll" style="animation-delay:0.12s">
            AI adoption is not a technology problem. It is a people architecture problem. When you deploy AI into a structure that is already strained, you do not reduce friction. You accelerate it.
          </p>
          <p class="font-body text-base text-muted leading-relaxed mb-10 max-w-2xl mx-auto lg:mx-0 animate-on-scroll" style="animation-delay:0.16s">
            The Frictionless Manager Bootcamp is an intensive 2-day experience that equips your middle managers with the diagnostic tools, decision frameworks, and structural clarity they need to lead through AI adoption without burning out, checking out, or collapsing the organizational architecture that must carry the transition.
          </p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-4 animate-on-scroll" style="animation-delay:0.2s">
            <a href={calendarUrl} target="_blank" rel="noopener noreferrer" class="btn-teal text-base !py-3.5 !px-7">
              Book an Executive Briefing
              <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
            <a href="#who-this-is-for" class="btn-outline-teal text-base !py-3.5">
              Is This Right for Your Organization?
            </a>
          </div>
        </div>

        <!-- Right: Event format card -->
        <div class="lg:col-span-5 animate-on-scroll" style="animation-delay:0.25s">
          <div class="card border-teal-DEFAULT/30 p-8">
            <p class="font-heading text-light text-lg font-semibold mb-6">The Bootcamp at a Glance</p>
            <div class="space-y-4">
              {[
                { label: 'Format', value: '2 days, in-person' },
                { label: 'IRL Location', value: 'SpringHill Suites Orlando Airport' },
                { label: 'Schedule', value: 'Alternating in-person and virtual cohorts' },
                { label: 'Next Date', value: 'October 2–3, 2026 | SpringHill Suites Orlando Airport | Founding Cohort' },
                { label: 'Who Attends', value: 'Middle managers and their leadership teams' },
                { label: 'Group Size', value: '20 attendees' },
                { label: 'Outcome', value: 'Structural clarity and a 90-day action plan' },
              ].map((item) => (
                <div class="flex gap-4 border-b border-border pb-4 last:border-0 last:pb-0">
                  <p class="text-teal-DEFAULT text-xs uppercase tracking-widest font-bold shrink-0 w-28 pt-0.5">{item.label}</p>
                  <p class="text-muted text-sm leading-relaxed">{item.value}</p>
                </div>
              ))}
            </div>
            <div class="mt-6 pt-6 border-t border-border">
              <p class="text-muted text-xs italic">Founding Cohort: $1,497 per seat. Price increases to $1,750 for cohort two. Corporate onsite pricing scoped during Executive Briefing.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-28" style="background: linear-gradient(to bottom, transparent, #0f172a);"></div>
  </section>


  <!-- ─── PROMO VIDEO ──────────────────────────────── -->
  <section class="py-20 bg-[#0f172a]">
    <div class="container-mid">
      <div class="text-center mb-10 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Watch the Overview</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          See what the Bootcamp is really about.
        </h2>
      </div>
      <div class="max-w-3xl mx-auto animate-on-scroll" style="animation-delay:0.08s">
        <div class="relative w-full rounded-lg overflow-hidden border border-teal-DEFAULT/30 shadow-2xl" style="aspect-ratio: 16 / 9;">
          <iframe
            src="https://app.heygen.com/embeds/297abb3af76a4de192d2a66279ff2e55"
            title="Frictionless Manager Bootcamp Promo"
            class="absolute inset-0 w-full h-full"
            allow="autoplay; fullscreen"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── QUIZ ENTRY POINT ─────────────────────────── -->
  <section class="py-12 bg-[#0c1525]">
    <div class="container-wide max-w-3xl mx-auto text-center">
      <p class="text-teal-DEFAULT text-xs uppercase tracking-widest mb-3 font-bold">Not sure if the Bootcamp is right for your team?</p>
      <h2 class="font-heading text-light text-2xl md:text-3xl mb-4 leading-snug">
        Take the 3-minute AI Readiness Quiz.
      </h2>
      <p class="text-muted text-base mb-6 max-w-xl mx-auto leading-relaxed">
        Answer six questions and get a personalized profile that tells you whether the Frictionless Manager Bootcamp fits where your organization actually is right now.
      </p>
      <a href="/strategic-reset/quiz/" class="btn-teal text-base !py-3 !px-7 inline-flex">
        Start the Quiz &rarr;
      </a>
    </div>
  </section>


  <!-- ─── PHOTO BREAK 1 ─────────────────────────────── -->
  <div class="w-full h-64 md:h-80 overflow-hidden">
    <img
      src="/images/bootcamp/diverse-women-team.jpg"
      alt="Diverse professional women collaborating in a modern workplace"
      class="w-full h-full object-cover opacity-80"
      style="object-position: center 20%;"
      loading="lazy"
    />
  </div>


  <!-- ─── THE REAL PROBLEM ──────────────────────────── -->
  <section class="py-20 bg-[#0c1525]">
    <div class="container-wide">
      <div class="max-w-2xl mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">The Real Problem</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          AI is not the friction. The structure underneath it is.
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          'Middle managers are being asked to implement AI tools they were not trained to evaluate.',
          'Decision rights are unclear, so every AI-related choice becomes a political negotiation.',
          'Your best managers are absorbing the anxiety of their teams, acting as human shock absorbers for structural failures.',
          'Role confusion is accelerating. AI is not clarifying who does what. It is exposing what was never clear.',
          'Change fatigue is real. Every new tool feels like another demand on people who are already at capacity.',
          'Organizations are measuring AI adoption by tool usage, not by whether the structure can actually support the load path.',
        ].map((pain, i) => (
          <div class="card teal-hover flex items-start gap-3 animate-on-scroll" style={`animation-delay:${i * 0.05}s`}>
            <span class="text-teal-DEFAULT shrink-0 mt-1 text-sm">→</span>
            <p class="text-muted text-sm leading-relaxed">{pain}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── WHAT THE BOOTCAMP DOES ───────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(13,148,136,0.05) 0%, transparent 65%);"></div>
    <div class="container-wide relative z-10">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">What the Bootcamp Delivers</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          From friction to frictionless. In 2 days.
        </h2>
        <p class="text-muted text-sm mt-3 max-w-lg mx-auto">
          The full-day experience is structured to move your team from diagnosis to direction before they leave the room.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          {
            num: '01',
            title: 'Structural Strain Diagnosis',
            desc: 'Using the UNMASK Framework, we identify where friction is actually coming from in your organization. No assumptions. No guesswork. Real structural data.',
          },
          {
            num: '02',
            title: 'AI Decision Rights Clarity',
            desc: 'Managers leave with a clear map of who decides what when AI is involved. Role confusion is the number one driver of AI adoption failure. We fix the architecture.',
          },
          {
            num: '03',
            title: 'Load Path Mapping',
            desc: 'We identify which managers are carrying invisible overload and redesign how work, accountability, and authority flow through the middle layer of your organization.',
          },
          {
            num: '04',
            title: 'Human Sustainability Framework',
            desc: 'AI adoption that does not account for human capacity will fail. Managers learn to pace transformation around the structure that must carry it.',
          },
          {
            num: '05',
            title: 'Structural Survival Architecture',
            desc: 'The managers most likely to break are the ones absorbing the most friction. This bootcamp directly addresses the structural conditions driving organizational collapse, giving you a framework to survive the human x AI transition.',
          },
          {
            num: '06',
            title: '90-Day Action Plan',
            desc: 'Every organization leaves with a specific, prioritized 90-day structural action plan built for their context. Not a binder of best practices. A real roadmap.',
          },
        ].map((item) => (
          <div class="card teal-hover animate-on-scroll">
            <p class="font-heading text-teal-DEFAULT text-3xl font-bold mb-3">{item.num}</p>
            <p class="font-heading text-light font-semibold text-lg mb-3">{item.title}</p>
            <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── PHOTO BREAK 2 ─────────────────────────────── -->
  <div class="w-full h-64 md:h-80 overflow-hidden">
    <img
      src="/images/bootcamp/team-collaboration-laptops.jpg"
      alt="Diverse team collaborating with laptops and tablets in a bright office"
      class="w-full h-full object-cover opacity-80"
      style="object-position: center 15%;"
      loading="lazy"
    />
  </div>


  <!-- ─── WHO THIS IS FOR ───────────────────────────── -->
  <section id="who-this-is-for" class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">
        <div class="animate-on-scroll">
          <span class="st-tag mb-5 inline-flex">Who This Is For</span>
          <h2 class="font-heading text-2xl md:text-3xl text-light mb-6">
            This bootcamp is built for organizations that are honest about what is happening.
          </h2>
          <div class="space-y-3">
            {[
              'Mid-sized organizations (50 to 500 employees) in active AI adoption or planning phases',
              'CNOs, COOs, and operational leaders who know their middle managers are strained but cannot yet prove it structurally',
              'Leadership teams where AI tools have been deployed but adoption is uneven, anxious, or stalled',
              'Organizations seeing structural strain concentrate around high-performing managers',
              'Executive teams preparing for a major transformation initiative and want to protect the people layer first',
              'HR leaders who are tired of engagement surveys that name the symptoms but never fix the design',
            ].map((item) => (
              <div class="flex items-start gap-3 p-4 bg-surface border border-border rounded-md hover:border-teal-DEFAULT/40 transition-colors">
                <span class="text-teal-DEFAULT shrink-0 mt-0.5">&#10003;</span>
                <p class="text-muted text-sm">{item}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="animate-on-scroll" style="animation-delay:0.1s">
          <span class="st-tag mb-5 inline-flex" style="color: #f87171; border-color: rgba(248,113,113,0.3);">Who This Is Not For</span>
          <h2 class="font-heading text-2xl md:text-3xl text-light mb-6">
            This engagement is not right for every organization.
          </h2>
          <div class="space-y-3 mb-8">
            {[
              'Organizations looking for a one-day training that checks a compliance box',
              'Leadership teams unwilling to examine the structure, only the people in it',
              'Organizations where the decision-maker is not part of the conversation',
              'Teams seeking a motivational speaker who will affirm rather than diagnose',
              'Those expecting a quick fix for a multi-year systemic problem',
            ].map((item) => (
              <div class="flex items-start gap-3 p-4 bg-surface border border-red-500/15 rounded-md">
                <span class="text-red-400/70 shrink-0 mt-0.5">&#10007;</span>
                <p class="text-muted text-sm">{item}</p>
              </div>
            ))}
          </div>
          <div class="bg-teal-glow border border-teal-DEFAULT/30 rounded-md p-5">
            <p class="font-heading text-teal-DEFAULT font-semibold text-sm mb-2">A note on fit:</p>
            <p class="text-muted text-sm leading-relaxed">
              Not every organization is ready for this work, and that is not a judgment. Every engagement begins with an Executive Briefing so we can assess fit, scope, and readiness together before any proposal is created.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── PHOTO BREAK 3 ─────────────────────────────── -->
  <div class="w-full h-64 md:h-80 overflow-hidden">
    <img
      src="/images/bootcamp/audience-applause.jpg"
      alt="Engaged diverse audience applauding at a professional leadership event"
      class="w-full h-full object-cover opacity-80"
      style="object-position: center 25%;"
      loading="lazy"
    />
  </div>


  <!-- ─── DELIVERY FORMAT ───────────────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(13,148,136,0.05) 0%, transparent 65%);"></div>
    <div class="container-mid relative z-10">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Delivery Format</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          2 Days. Two ways to experience it.
        </h2>
        <p class="text-muted text-sm mt-3 max-w-lg mx-auto">
          The Frictionless Manager Bootcamp alternates between in-person and virtual cohorts so your team can participate in the format that works best for them.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-3xl mx-auto">
        {[
          {
            tag: 'In-Person',
            name: 'Orlando, FL',
            icon: '📍',
            desc: 'The 2-day bootcamp hosted live at SpringHill Suites Orlando Airport. Designed for high-impact, in-room engagement with your leadership team. Additional cities will be added as cohorts grow.',
            note: 'Additional IRL locations coming soon.',
          },
          {
            tag: 'Virtual',
            name: 'Live Online Cohort',
            icon: '💻',
            desc: 'The same 2-day experience delivered virtually. Structured for real engagement, not passive viewing. Includes all diagnostic tools, frameworks, and the 90-day action plan.',
            note: 'Alternates with in-person cohorts throughout the year.',
            featured: true,
          },
        ].map((item) => (
          <div class={`card flex flex-col text-center animate-on-scroll ${item.featured ? 'border-teal-DEFAULT/50 bg-teal-DEFAULT/5' : 'teal-hover'}`}>
            <span class="text-3xl mb-4 block">{item.icon}</span>
            <p class="text-teal-DEFAULT text-xs uppercase tracking-[0.22em] mb-2">{item.tag}</p>
            <p class="font-heading text-light text-2xl mb-4">{item.name}</p>
            <p class="text-muted text-sm leading-relaxed mb-4 flex-1">{item.desc}</p>
            <p class="text-teal-DEFAULT/70 text-xs italic">{item.note}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-muted text-sm mt-8 max-w-xl mx-auto">
        All engagements are proposal-based and scoped during the Executive Briefing. Pricing and available cohort dates are shared at that time.
      </p>
    </div>
  </section>


  <!-- ─── FINAL CTA ─────────────────────────────────── -->
  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 80% at 50% 50%, rgba(13,148,136,0.07) 0%, transparent 65%);"></div>
    <div class="container-narrow relative z-10 text-center animate-on-scroll">
      <h2 class="font-heading text-3xl md:text-5xl text-light mb-5 leading-tight">
        Ready to reduce the friction<br/>
        <span class="text-teal-DEFAULT">before it costs you your best people?</span>
      </h2>
      <p class="text-muted text-lg leading-relaxed mb-10 max-w-xl mx-auto">
        Every engagement begins with an Executive Briefing. Book a time to talk through what is happening in your organization and whether the Frictionless Manager Bootcamp is the right fit.
      </p>
      <a href={calendarUrl} target="_blank" rel="noopener noreferrer" class="btn-teal text-base !py-4 !px-8">
        Book an Executive Briefing &rarr;
      </a>
    </div>
  </section>

</Layout>
