---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" section="home">
  <section class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="text-center">
      <p class="font-heading text-8xl text-teal-DEFAULT/20 font-bold mb-4">404</p>
      <h1 class="font-heading text-3xl text-light mb-3">This page doesn't exist.</h1>
      <p class="text-muted mb-8">
        Structures fail when the design doesn't account for human navigation.
        Let's get you back to solid ground.
      </p>
      <a href="/" class="btn-teal">Return to Homepage →</a>
    </div>
  </section>
</Layout>
