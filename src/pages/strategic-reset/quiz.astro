  <!-- ─── STYLES ───────────────────────────────────── -->
  <style>
    .quiz-option {
      display: block;
      cursor: pointer;
    }
    .quiz-option-inner {
      display: block;
      padding: 1rem 1.25rem;
      border: 1px solid var(--color-border, #1e293b);
      border-radius: 0.5rem;
      color: var(--color-muted, #94a3b8);
      font-size: 0.95rem;
      line-height: 1.6;
      transition: border-color 0.2s, background-color 0.2s, color 0.2s;
      background: var(--color-surface, #0f172a);
    }
    .quiz-option:hover .quiz-option-inner {
      border-color: #0d9488;
      color: #e2e8f0;
    }
    .quiz-option.selected .quiz-option-inner {
      border-color: #0d9488;
      background: rgba(13,148,136,0.08);
      color: #e2e8f0;
    }
    .quiz-option:focus-within .quiz-option-inner {
      outline: 2px solid #0d9488;
      outline-offset: 2px;
    }
    .hidden { display: none; }
  </style>


  <!-- ─── QUIZ LOGIC ───────────────────────────────── -->
  <script define:vars={{ GHL_WEBHOOK_URL }}>
    let selectedTrack = null;
    const answers = {};

    function updateProgress(step) {
      const wrap = document.getElementById('quiz-progress-wrap');
      // Hide progress bar on the gate question.
      if (step === 'gate') {
        if (wrap) wrap.classList.add('hidden');
        return;
      }
      if (wrap) wrap.classList.remove('hidden');

      const steps = ['1','2','3','4','5'];
      const idx = steps.indexOf(String(step));
      const pct = idx < 0 ? 100 : Math.round((idx / 5) * 100);
      const bar = document.getElementById('progress-bar');
      const label = document.getElementById('progress-label');
      const pctEl = document.getElementById('progress-pct');
      if (bar) bar.style.width = pct + '%';
      if (label) label.textContent = idx >= 0 ? `Question ${idx + 1} of 5` : 'Almost there!';
      if (pctEl) pctEl.textContent = pct + '%';
    }

    function showStep(step) {
      document.querySelectorAll('.quiz-step').forEach(el => el.classList.add('hidden'));

      let target;
      if (step === 'gate' || step === 'capture') {
        target = document.querySelector(`.quiz-step[data-step="${step}"]`);
      } else {
        // Track-aware lookup for diagnostic questions.
        target = document.querySelector(`.quiz-step[data-step="${step}"][data-track="${selectedTrack}"]`);
      }

      if (target) {
        target.classList.remove('hidden');
        updateProgress(step);
        window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 100, behavior: 'smooth' });
      }
    }

    function resetDiagnosticAnswers() {
      ['q1','q2','q3','q4','q5'].forEach(k => { delete answers[k]; });
      // Visually clear any previously selected options across both tracks.
      document.querySelectorAll('.quiz-step[data-track] .quiz-option.selected').forEach(o => o.classList.remove('selected'));
      document.querySelectorAll('.quiz-step[data-track] input[type="radio"]:checked').forEach(i => { i.checked = false; });
      document.querySelectorAll('.quiz-step[data-track] .quiz-next').forEach(b => b.setAttribute('disabled', ''));
    }

    // Option selection
    document.querySelectorAll('.quiz-option').forEach(option => {
      option.addEventListener('click', () => {
        const stepEl = option.closest('.quiz-step');
        const step = stepEl.dataset.step;
        const val = option.dataset.value;

        if (step === 'gate') {
          if (selectedTrack && selectedTrack !== val) {
            // Track changed. Clear prior diagnostic answers so scoring is clean.
            resetDiagnosticAnswers();
          }
          selectedTrack = val;
          answers.gate = val;
        } else {
          answers[`q${step}`] = parseInt(val);
        }

        // Deselect siblings within this step.
        option.closest('.space-y-4').querySelectorAll('.quiz-option').forEach(o => o.classList.remove('selected'));
        option.classList.add('selected');

        // Sync the hidden radio input for accessibility and form semantics.
        const input = option.querySelector('input[type="radio"]');
        if (input) input.checked = true;

        // Enable next button on this step.
        const nextBtn = stepEl.querySelector('.quiz-next');
        if (nextBtn) nextBtn.removeAttribute('disabled');
      });

      // Keyboard support: Enter or Space activates the option.
      option.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          option.click();
        }
      });
      // Make options focusable for keyboard navigation.
      option.setAttribute('tabindex', '0');
      option.setAttribute('role', 'radio');
    });

    // Next buttons
    document.querySelectorAll('.quiz-next').forEach(btn => {
      btn.addEventListener('click', () => {
        const next = btn.dataset.next;
        showStep(next);
      });
    });

    // Back buttons
    document.querySelectorAll('.quiz-back').forEach(btn => {
      btn.addEventListener('click', () => {
        showStep(btn.dataset.back);
      });
    });

    // ─── Result determination per track ────────────────────────────────────
    function determineResult() {
      const score = ['q1','q2','q3','q4','q5'].reduce((sum, k) => sum + (answers[k] || 0), 0);

      let profileSlug;   // for DOM lookup (data-profile attribute)
      let profileFull;   // for webhook payload

      if (selectedTrack === 'A') {
        if (score >= 12)      { profileSlug = 'strategic';  profileFull = 'strategic_manager'; }
        else if (score >= 8)  { profileSlug = 'curious';    profileFull = 'curious_manager'; }
        else                  { profileSlug = 'overwhelmed'; profileFull = 'overwhelmed_manager'; }
      } else {
        if (score >= 12)      { profileSlug = 'architect';  profileFull = 'strategic_architect'; }
        else if (score >= 8)  { profileSlug = 'curious';    profileFull = 'curious_contributor'; }
        else                  { profileSlug = 'overwhelmed'; profileFull = 'overwhelmed_operator'; }
      }

      return { score, profileSlug, profileFull };
    }

    // ─── UNMASK pattern flags (Track A only) ───────────────────────────────
    // Q1 = RAA + ITC, Q2 = SSS, Q3 = LMI, Q4 = ABAI.
    // A flag is set true when the user picked the highest-strain option (1).
    function buildUnmaskFlags() {
      if (selectedTrack !== 'A') return null;
      return {
        raa_high:  answers.q1 === 1,
        sss_high:  answers.q2 === 1,
        lmi_high:  answers.q3 === 1,
        abai_high: answers.q4 === 1,
      };
    }

    // ─── Recommended next step routing ─────────────────────────────────────
    const recommendations = {
      A: {
        overwhelmed_manager: { primary: 'executive_brief_pdf',     secondary: 'bootcamp_register_sept_2026' },
        curious_manager:     { primary: 'bootcamp_register_sept_2026', secondary: 'executive_brief_pdf' },
        strategic_manager:   { primary: 'bootcamp_executive_briefing', secondary: 'bootcamp_register_sept_2026' },
      },
      B: {
        overwhelmed_operator: { primary: 'sri_apply', secondary: null },
        curious_contributor:  { primary: 'sri_apply', secondary: null },
        strategic_architect:  { primary: 'sri_apply', secondary: null },
      },
    };

    // Email capture form submission
    document.getElementById('quiz-capture-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('quiz-name').value.trim();
      const email = document.getElementById('quiz-email').value.trim();
      if (!name || !email) return;

      const { score, profileSlug, profileFull } = determineResult();
      const unmaskFlags = buildUnmaskFlags();
      const rec = recommendations[selectedTrack][profileFull] || { primary: null, secondary: null };

      // ─── GHL WEBHOOK SUBMISSION ──────────────────────────────────────────────
      // Replace GHL_WEBHOOK_URL above with your actual GHL webhook once transfer
      // is done. The payload below carries everything the CRM needs to segment
      // leads by track, profile, score, and UNMASK pattern flags.
      //
      // Sabbath note: this submission fires in real time so the user sees
      // their results immediately. Downstream automations (welcome email,
      // nurture, sales outreach) MUST honor the Friday sundown to Saturday
      // sundown delay window. Configure that at the GHL workflow level.
      if (GHL_WEBHOOK_URL && GHL_WEBHOOK_URL !== 'REPLACE_WITH_GHL_WEBHOOK_URL') {
        try {
          await fetch(GHL_WEBHOOK_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name,
              email,
              track: selectedTrack,
              score,
              profile: profileFull,
              source: 'AI Readiness Quiz',
              source_variant: selectedTrack === 'A' ? 'track_a_manager' : 'track_b_transition',
              answers: { ...answers },
              unmask_flags: unmaskFlags,
              recommended_next_step: rec.primary,
              secondary_path: rec.secondary,
              submitted_at: new Date().toISOString(),
              page_url: window.location.href,
            }),
          });
        } catch (err) {
          console.warn('Webhook submission failed:', err);
        }
      }
      // ─────────────────────────────────────────────────────────────────────────

      // Show results
      document.getElementById('quiz-questions').classList.add('hidden');
      document.getElementById('quiz-progress-wrap').classList.add('hidden');
      const resultsEl = document.getElementById('quiz-results');
      resultsEl.classList.remove('hidden');
      document.querySelectorAll('.quiz-result').forEach(r => r.classList.add('hidden'));
      const resultEl = document.querySelector(`.quiz-result[data-track="${selectedTrack}"][data-profile="${profileSlug}"]`);
      if (resultEl) {
        resultEl.classList.remove('hidden');
        window.scrollTo({ top: resultsEl.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
      }
    });
  </script>

