---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Nikki Cates — Structural Recalibration Strategist"
  description="Organizations don't burn people out. Structures do. Nikki Cates helps executives diagnose and dismantle the structural conditions driving attrition, silenced talent, and systemic exhaustion."
  section="home"
  accentColor="teal"
>

  <!-- ─── HERO ─────────────────────────────────────── -->
  <section class="relative min-h-[94vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-[#0f172a]"></div>
    <!-- Gradient atmosphere -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 70% at 65% 45%, rgba(13,148,136,0.08) 0%, transparent 65%), radial-gradient(ellipse 50% 60% at 5% 85%, rgba(15,76,122,0.1) 0%, transparent 55%);"></div>
    <!-- Left vertical accent -->
    <div class="absolute left-0 top-0 bottom-0 w-[3px]" style="background: linear-gradient(to bottom, transparent 5%, #0d9488 25%, #0d9488 75%, transparent 95%);"></div>

    <div class="container-wide relative z-10 py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

        <!-- Left: Core message -->
        <div class="lg:col-span-7">
          <div class="st-tag mb-6 animate-on-scroll">
            <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
            Structural Recalibration Strategist · AI-Era Organizational Strategist
          </div>

          <h1 class="font-heading font-bold text-light leading-[1.06] mb-6 animate-on-scroll" style="font-size: clamp(2.4rem, 5.5vw, 4.2rem); animation-delay:0.05s">
            Your people aren't<br/>
            <span class="text-teal-DEFAULT italic">burning out.</span><br/>
            Your structure is.
          </h1>

          <p class="font-body text-lg text-muted leading-relaxed mb-2 max-w-2xl animate-on-scroll" style="animation-delay:0.15s">
            Nikki Cates is the Structural Recalibration Strategist who helps executives and boards
            diagnose and dismantle the hidden architectures producing burnout, attrition, and
            silenced capacity, before the cost becomes catastrophic.
          </p>
          <p class="font-body text-base text-muted leading-relaxed mb-10 max-w-2xl animate-on-scroll" style="animation-delay:0.2s">
            Army veteran. Womanist theologian. Creator of the <span class="text-teal-DEFAULT font-semibold">UNMASK Framework</span>. Author of the UNMASK Blueprint Series. Founder of Strategic Transformations &amp; URI.
          </p>

          <div class="flex flex-wrap gap-4 mb-12 animate-on-scroll" style="animation-delay:0.25s">
            <a href="/structural-burnout/briefing" class="btn-teal text-base !py-3.5 !px-7">
              Request Executive Briefing
              <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
            <a href="/structural-burnout/" class="btn-outline-teal text-base !py-3.5">
              Explore the Work
            </a>
          </div>

          <!-- Social proof bar -->
          <div class="flex flex-wrap gap-6 animate-on-scroll" style="animation-delay:0.3s">
            {[
              { num: '15+', label: 'Yrs Organizational Practice' },
              { num: '3', label: 'Diagnostic Volumes Published' },
              { num: '3', label: 'Diagnostic Volumes Published' },
              { num: '$12.5K', label: 'Speaking Starts At' },
            ].map((s) => (
              <div class="border-l-2 border-teal-DEFAULT/40 pl-3">
                <p class="font-heading text-xl text-teal-DEFAULT font-bold leading-none">{s.num}</p>
                <p class="text-muted text-xs mt-1">{s.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Photo + credential -->
        <div class="lg:col-span-5 flex flex-col gap-4 animate-on-scroll" style="animation-delay:0.35s">

          <!-- Photo -->
          <div class="relative rounded-lg overflow-hidden border border-teal-DEFAULT/25"
               style="background: linear-gradient(135deg, #0a2540 0%, #0f172a 100%);">
            <img
              src="/images/nikki-cates.png"
              alt="Nikki Cates — Structural Recalibration Strategist"
              class="w-full h-auto object-cover object-top"
              style="max-height: 420px; object-position: center top;"
            />
            <!-- Photo overlay tag -->
            <div class="absolute bottom-0 left-0 right-0 p-4"
                 style="background: linear-gradient(to top, rgba(15,23,42,0.92) 60%, transparent);">
              <p class="font-heading text-light text-sm font-semibold">Nikki Cates</p>
              <p class="text-teal-DEFAULT text-xs font-body font-bold uppercase tracking-widest">
                Structural Recalibration Strategist
              </p>
            </div>
          </div>

          <!-- Credential pills -->
          <div class="grid grid-cols-2 gap-3">
            {[
              { icon: '🎖️', label: 'Army Veteran' },
              { icon: '✍🏾', label: 'Womanist Scholar' },
              { icon: '📖', label: 'Published Author' },
              { icon: '🌍', label: 'Keynote Speaker' },
            ].map((item) => (
              <div class="card teal-hover flex items-center gap-3 py-3 px-4">
                <span class="text-xl shrink-0">{item.icon}</span>
                <p class="font-heading text-light font-semibold text-xs">{item.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-28" style="background: linear-gradient(to bottom, transparent, #0f172a);"></div>
  </section>


  <!-- ─── PAIN POINT RECOGNITION ───────────────────── -->
  <section class="py-20 bg-[#0c1525]">
    <div class="container-wide">
      <div class="max-w-2xl mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">You're Here Because</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          Something inside your organization<br/>is <em class="not-italic text-teal-DEFAULT">breaking</em> — and you can feel it.
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          'Your best people keep leaving, and nobody can tell you why.',
          'Leadership is exhausted, and pretending otherwise.',
          'You\'ve done the trainings, the surveys, the retreats. Nothing sticks.',
          'Your DEI efforts are real, but the most marginalized talent is still burning out.',
          'Urgency has become the culture. Everything is critical. Nothing gets done well.',
          'You\'re watching institutional knowledge walk out the door with every departure.',
          'AI tools are being deployed, and nobody is asking what it\'s doing to your people.',
          'The pipeline looks strong on paper. In practice, leaders are struggling.',
          'You know the structure is the problem. You don\'t know how to name it yet.',
        ].map((pain, i) => (
          <div class="card teal-hover flex items-start gap-3 animate-on-scroll" style={`animation-delay:${i * 0.05}s`}>
            <span class="text-teal-DEFAULT shrink-0 mt-1 text-sm">→</span>
            <p class="text-muted text-sm leading-relaxed">{pain}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center animate-on-scroll">
        <p class="font-heading text-xl text-light mb-2">If any of that landed, you're in the right place.</p>
        <p class="text-muted text-sm mb-6 max-w-lg mx-auto">
          These are not performance problems. They are structural ones.
          And there is a framework designed to diagnose and dismantle them.
        </p>
        <a href="/structural-burnout/" class="btn-teal">See How the Work Works →</a>
      </div>
    </div>
  </section>


  <!-- ─── TRANSFORMATION OUTCOMES ──────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(13,148,136,0.05) 0%, transparent 65%);"></div>
    <div class="container-wide relative z-10">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">The Shift</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">What changes when you fix the design.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border max-w-4xl mx-auto rounded-lg overflow-hidden">
        {[
          { before: 'Treating burnout as individual weakness', after: 'Diagnosing it as organizational design failure' },
          { before: 'Watching talent leave without understanding why', after: 'Mapping the exact structural conditions driving attrition' },
          { before: 'Reactive engagement surveys after damage is done', after: 'Proactive structural monitoring built into operations' },
          { before: 'DEI programs layered on top of broken infrastructure', after: 'Structural redesign that makes inclusion architecturally possible' },
          { before: 'AI tools deployed without human architecture assessment', after: 'Strategic integration that protects human capacity' },
          { before: '"Everything is urgent" leadership culture', after: 'Sovereign operational rhythms with real accountability structures' },
        ].map((item) => (
          <div class="bg-surface p-6 flex gap-6 items-start">
            <div class="flex-1">
              <p class="text-xs font-body font-bold uppercase tracking-widest text-red-400/70 mb-2">Before</p>
              <p class="text-muted text-sm">{item.before}</p>
            </div>
            <div class="text-teal-DEFAULT/40 text-xl shrink-0 mt-3">→</div>
            <div class="flex-1">
              <p class="text-xs font-body font-bold uppercase tracking-widest text-teal-DEFAULT mb-2">After</p>
              <p class="text-light text-sm font-medium">{item.after}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── FEATURED WORK / ENTRY POINTS ─────────────── -->
  <section class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">The Ecosystem</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">Where do you need to go?</h2>
        <p class="text-muted text-sm mt-3 max-w-md mx-auto">
          Every entry point is intentional. None lead directly to a calendar without a vetting conversation first.
        </p>
      </div>

      <!-- 3-column primary entries -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
        {[
          {
            href: '/structural-burnout/',
            accent: 'teal',
            label: 'Structural Burnout',
            badge: 'Core Work',
            desc: 'The diagnostic practice for organizations burning through their most committed talent. Burnout is a design flaw, and there\'s a framework to fix it.',
            cta: 'Enter the Hub →',
          },
          {
            href: '/structural-burnout/services',
            accent: 'teal',
            label: 'Services & Pricing',
            badge: 'Start Here',
            desc: 'From $12,500 keynotes to $45,000 recalibration engagements. All begin with a vetting conversation. Explore the full architecture.',
            cta: 'View Services →',
          },
          {
            href: '/uri/',
            accent: 'gold',
            label: 'URI Formation',
            badge: 'Justice Work',
            desc: 'Liberation-grounded leadership formation at the intersection of womanist theology, structural analysis, and right relationship.',
            cta: 'Enter Formation →',
          },
        ].map((item) => (
          <a href={item.href} class={`card ${item.accent === 'gold' ? 'gold-hover' : 'teal-hover'} flex flex-col gap-3 group no-underline animate-on-scroll`}>
            <div class="flex items-center justify-between mb-1">
              <span class={item.accent === 'gold' ? 'uri-tag' : 'st-tag'}>{item.badge}</span>
            </div>
            <h3 class={`font-heading text-xl font-bold ${item.accent === 'gold' ? 'text-gold' : 'text-teal-DEFAULT'}`}>{item.label}</h3>
            <p class="text-muted text-sm leading-relaxed flex-1">{item.desc}</p>
            <span class={`text-xs font-body font-bold uppercase tracking-widest mt-2 group-hover:translate-x-1 inline-block transition-transform ${item.accent === 'gold' ? 'text-gold' : 'text-teal-DEFAULT'}`}>{item.cta}</span>
          </a>
        ))}
      </div>

      <!-- 4-column secondary entries -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { href: '/structural-burnout/briefing', icon: '📋', label: 'Executive Briefing', desc: 'High-commitment vetting entry' },
          { href: '/structural-burnout/pitch',    icon: '💼', label: 'Investor Hub', desc: 'Thesis, traction & opportunity' },
          { href: '/books/',                       icon: '📖', label: 'UNMASK Series', desc: 'Vol. 1, 2 & 3 available now' },
          { href: '/structural-burnout/nexus',    icon: '🪪', label: 'Nexus Card', desc: 'Digital networking card' },
        ].map((item) => (
          <a href={item.href} class="card teal-hover flex flex-col gap-2 animate-on-scroll group no-underline">
            <span class="text-2xl">{item.icon}</span>
            <p class="font-heading text-light font-semibold text-sm">{item.label}</p>
            <p class="text-muted text-xs">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── SIGNATURE TALKS ───────────────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 70% at 80% 50%, rgba(13,148,136,0.06) 0%, transparent 60%);"></div>
    <div class="container-wide relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <div class="lg:col-span-2 animate-on-scroll">
          <span class="st-tag mb-5 inline-flex">2026 Speaking</span>
          <h2 class="font-heading text-3xl md:text-4xl text-light mb-5">
            Five talks.<br/>One through line.
          </h2>
          <p class="text-muted text-sm leading-relaxed mb-6">
            Nikki Cates is a keynote speaker whose talks move rooms, not because they inspire,
            but because they diagnose. Your organization will not be the same after.
          </p>
          <p class="font-body text-sm mb-6">
            <span class="text-teal-DEFAULT font-semibold">Speaking starts at $12,500.</span>
            <span class="text-muted"> All inquiries begin with the Executive Briefing form.</span>
          </p>
          <a href="/structural-burnout/briefing" class="btn-teal !text-sm">
            Inquire About Speaking →
          </a>
        </div>

        <div class="lg:col-span-3 space-y-3 animate-on-scroll" style="animation-delay:0.15s">
          {[
            { num: '01', title: 'Stop the Strain Transfer', tag: 'Culture' },
            { num: '02', title: 'Your Leadership Pipeline Is Leaking', tag: 'Talent' },
            { num: '03', title: 'False Urgency: How "Everything Is Critical" Is Destroying Your Organization', tag: 'Operations' },
            { num: '04', title: 'Sovereign Power: Leading Without Running on Empty', tag: 'Leadership' },
            { num: '05', title: 'When AI Breaks the Bridge: Protecting Human Architecture in the Age of Automation', tag: 'AI + Future' },
          ].map((talk) => (
            <div class="flex items-center gap-4 card teal-hover py-4 px-5 group">
              <span class="font-heading text-3xl text-teal-DEFAULT/20 font-bold leading-none shrink-0">{talk.num}</span>
              <p class="font-heading text-light text-sm font-semibold flex-1">"{talk.title}"</p>
              <span class="st-tag text-xs shrink-0 hidden md:inline-flex">{talk.tag}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ─── UNMASK SERIES CALLOUT ─────────────────────── -->
  <section class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div class="animate-on-scroll">
          <span class="st-tag mb-5 inline-flex">Signature Publications</span>
          <h2 class="font-heading text-3xl md:text-5xl text-light mb-5">
            The <span class="text-teal-DEFAULT">UNMASK</span><br/>Blueprint Series.
          </h2>
          <p class="text-muted leading-relaxed mb-4">
            Three volumes. One operational diagnostic system. Built for executives, consultants, and
            organizational architects who are done managing symptoms.
          </p>
          <p class="text-muted leading-relaxed mb-8">
            <strong class="text-light">Vol. 1 — Deconstruction of the Grind</strong> — Individual diagnostic: reclaiming sovereign softness from performative survival.
            <strong class="text-light"> Vol. 2 — Redesigning Systems</strong> — Institutional imperative: diagnosing authority gaps and AI-accelerated overload.
            <strong class="text-light"> Vol. 3 — The Soul of the System</strong> — Collective liberation: structural sovereignty for the leader done being the load path.
          </p>
          <a href="/books/" class="btn-teal">Access the Series →</a>
        </div>

        <div class="space-y-3 animate-on-scroll" style="animation-delay:0.2s">
          {[
            { letter: 'U', name: 'Uncover', desc: 'Surface the hidden strains — the masks — that individuals, teams, and institutions have normalized into invisibility.' },
            { letter: 'N', name: 'Navigate', desc: 'Chart the structural landscape and map the conditions driving exhaustion, attrition, and silenced capacity.' },
            { letter: 'M', name: 'Manage', desc: 'Develop recalibration strategies and implement structural redesign with clear accountability structures.' },
            { letter: 'A', name: 'Advocate', desc: 'Champion the structural and systemic changes required for human flourishing — at the individual, organizational, and collective level.' },
            { letter: 'S', name: 'Sustain', desc: 'Embed recalibration into the ongoing operational rhythm so transformation outlasts the engagement.' },
            { letter: 'K', name: 'Kindle', desc: 'Ignite collective capacity — relighting the fire in leaders, teams, and communities ready to lead without running on empty.' },
          ].map((p) => (
            <div class="flex items-start gap-4 p-4 rounded-md border border-border hover:border-teal-DEFAULT/30 transition-colors bg-surface/50">
              <span class="font-heading text-teal-DEFAULT text-2xl font-bold w-7 shrink-0">{p.letter}</span>
              <div>
                <p class="font-heading text-light font-semibold text-sm mb-1">{p.name}</p>
                <p class="text-muted text-xs leading-relaxed">{p.desc}</p>
              </div>
            </div>
          ))}
          <!-- Entry diagnostic -->
          <div class="p-4 rounded-md border border-teal-DEFAULT/30 bg-teal-DEFAULT/5">
            <p class="font-body text-xs font-bold uppercase tracking-widest text-teal-DEFAULT mb-1">Entry Diagnostic</p>
            <p class="text-light text-sm font-semibold">Structural Strain Score (SSS)</p>
            <p class="text-muted text-xs mt-1">The 9-question structural assessment that begins every UNMASK engagement.</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── TESTIMONIALS (placeholder, ready for real quotes) ── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(13,148,136,0.04) 0%, transparent 70%);"></div>
    <div class="container-wide relative z-10">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">What People Say</span>
        <h2 class="font-heading text-3xl text-light">The work speaks.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          {
            quote: 'Nikki named something in our organization that we had been circling around for years. The UNMASK process gave us language, clarity, and a path forward we didn\'t know we needed.',
            name: 'Executive Director',
            org: 'National Nonprofit Organization',
          },
          {
            quote: 'I brought Nikki in as a keynote speaker and had no idea the talk would shift the entire conversation at our conference. Every room needs this.',
            name: 'Conference Organizer',
            org: 'HR Leadership Summit',
          },
          {
            quote: 'This is not a wellness consultant. This is a structural architect who happens to also carry a theological depth that changes the room.',
            name: 'Chief People Officer',
            org: 'Mid-Market Enterprise',
          },
        ].map((t) => (
          <div class="card teal-hover flex flex-col gap-5 animate-on-scroll">
            <svg width="24" height="18" viewBox="0 0 24 18" fill="none" class="text-teal-DEFAULT/40 shrink-0">
              <path d="M0 18V10.8C0 7.4 1 4.6 3 2.4 5 0.8 7.6 0 10.8 0v3.6C8.8 3.6 7.4 4.2 6.6 5.4 5.8 6.6 5.4 8 5.4 9.6H10.8V18H0ZM13.2 18V10.8C13.2 7.4 14.2 4.6 16.2 2.4 18.2 0.8 20.8 0 24 0v3.6C22 3.6 20.6 4.2 19.8 5.4 19 6.6 18.6 8 18.6 9.6H24V18H13.2Z" fill="currentColor"/>
            </svg>
            <p class="text-muted text-sm leading-relaxed flex-1 italic">"{t.quote}"</p>
            <div class="border-t border-border pt-4">
              <p class="text-light text-sm font-semibold">{t.name}</p>
              <p class="text-muted text-xs">{t.org}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-xs text-muted mt-6 italic">
        Testimonials reflect client experiences. Names withheld for confidentiality. Replace with actual client quotes.
      </p>
    </div>
  </section>


  <!-- ─── URI CALLOUT ───────────────────────────────── -->
  <section class="section-pad bg-[#0c1525] relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 70% at 20% 50%, rgba(107,33,168,0.09) 0%, transparent 60%), radial-gradient(ellipse 40% 50% at 80% 30%, rgba(217,119,6,0.06) 0%, transparent 55%);"></div>
    <div class="container-mid relative z-10 animate-on-scroll">
      <div class="border border-plum-DEFAULT/30 rounded-lg p-10 md:p-14 bg-[#1a0a2e]/40">
        <div class="flex items-start gap-5 mb-6">
          <img src="/logos/uri-logo.png" alt="URI" width="160" height="36" class="h-14 w-auto" />
        </div>
        <h2 class="font-heading text-3xl md:text-4xl text-light mb-4">
          Liberation is the<br/>
          <span class="text-gold">theological work</span> of leadership.
        </h2>
        <p class="text-muted leading-relaxed mb-8 max-w-xl">
          Unbothered Resistance International is the justice-centered formation and research wing
          beneath everything Nikki builds. Rooted in womanist theology, structural analysis, and
          a commitment to restoring right relationships, in organizations, communities, and Spirit.
        </p>
        <a href="/uri/" class="btn-gold">Explore URI Formation →</a>
      </div>
    </div>
  </section>


  <!-- ─── FINAL CTA ─────────────────────────────────── -->
  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 80% at 50% 50%, rgba(13,148,136,0.07) 0%, transparent 65%);"></div>
    <div class="container-narrow relative z-10 text-center animate-on-scroll">
      <h2 class="font-heading text-3xl md:text-5xl text-light mb-5 leading-tight">
        The structure is<br/>
        <span class="text-teal-DEFAULT">fixable.</span>
      </h2>
      <p class="text-muted text-lg leading-relaxed mb-10 max-w-xl mx-auto">
        Every engagement begins with a conversation, not a calendar link.
        The vetting process exists to protect your investment and make sure
        every engagement is positioned for actual transformation.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/structural-burnout/briefing" class="btn-teal text-base !py-4 !px-8">
          Request Executive Briefing →
        </a>
        <a href="/structural-burnout/services" class="btn-outline-teal text-base !py-4">
          View All Services
        </a>
      </div>
    </div>
  </section>


  <!-- ─── AUTHORITY STRIP ───────────────────────────── -->
  <section class="py-8 bg-surface border-y border-border">
    <div class="container-wide">
      <div class="flex flex-wrap justify-center gap-8 md:gap-14 items-center">
        {['Army Veteran','UNMASK Framework Creator','Womanist Theologian','Structural Burnout Specialist','AI-Era Organizational Strategist','Published Author','Liberation Ethicist'].map((item) => (
          <span class="font-body text-xs font-bold uppercase tracking-widest text-muted">{item}</span>
        ))}
      </div>
    </div>
  </section>

</Layout>
