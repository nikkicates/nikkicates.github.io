---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Strategic Transformations | Nikki Cates"
  description="CEO-led Strategic Transformations helps high-burnout organizations in AI transformation build the middle layer AI can't replace through proprietary diagnostics, strategic advisory, and licensed frameworks."
  section="st"
  accentColor="teal"
>

  <!-- ─── HERO ─────────────────────────────────────── -->
  <section class="relative min-h-[94vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-[#0f172a]"></div>
    <!-- Gradient atmosphere -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 70% at 65% 45%, rgba(13,148,136,0.08) 0%, transparent 65%), radial-gradient(ellipse 50% 60% at 5% 85%, rgba(15,76,122,0.1) 0%, transparent 55%);"></div>
    <!-- Left vertical accent -->
    <div class="absolute left-0 top-0 bottom-0 w-[3px]" style="background: linear-gradient(to bottom, transparent 5%, #0d9488 25%, #0d9488 75%, transparent 95%);"></div>

    <div class="container-wide relative z-10 py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

        <!-- Left: Core message -->
        <div class="lg:col-span-7 text-center lg:text-left">
          <div class="st-tag mb-6 mx-auto lg:mx-0 animate-on-scroll">
            <svg width="6" height="6" viewBox="0 0 6 6" fill="currentColor"><circle cx="3" cy="3" r="3"/></svg>
            Strategic Transformations · AI-Era Organizational Strategy
          </div>

          <h1 class="font-heading font-bold text-light leading-[1.06] mb-6 animate-on-scroll" style="font-size: clamp(2.4rem, 5.5vw, 4.2rem); animation-delay:0.05s">
            Strategic<br/>
            <span class="text-teal-DEFAULT">Transformations</span>
          </h1>

          <p class="font-body text-teal-DEFAULT text-lg font-semibold italic leading-relaxed mb-6 max-w-2xl mx-auto lg:mx-0 animate-on-scroll" style="animation-delay:0.1s">
            Burnout is a design flaw. We fix the design.
          </p>

          <p class="font-body text-lg text-light leading-relaxed mb-4 max-w-2xl mx-auto lg:mx-0 animate-on-scroll" style="animation-delay:0.15s">
            AI does not create organizational dysfunction. It accelerates structural conditions that were already there.
          </p>
          <p class="font-body text-base text-muted leading-relaxed mb-10 max-w-2xl mx-auto lg:mx-0 animate-on-scroll" style="animation-delay:0.2s">
            We help organizations diagnose the structural strain AI is amplifying before it becomes attrition, failed adoption, or leadership collapse. Through proprietary diagnostics, strategic advisory, and the Frictionless Manager Bootcamp, we build the human architecture your next chapter depends on.
          </p>

          <div class="flex flex-wrap justify-center lg:justify-start gap-4 mb-12 animate-on-scroll" style="animation-delay:0.25s">
            <a href="https://calendar.app.google/e8ErMQqHhmnHn1hk6" target="_blank" rel="noopener noreferrer" class="btn-teal text-base !py-3.5 !px-7">
              Book an Executive Briefing
              <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
            <a href="/strategic-reset/" class="btn-outline-teal text-base !py-3.5">
              Explore the Work
            </a>
          </div>

          <!-- Social proof bar -->
          <div class="flex flex-wrap justify-center lg:justify-start gap-6 animate-on-scroll" style="animation-delay:0.3s">
            {[
              { num: '15+', label: 'Yrs Organizational Practice' },
              { num: '3', label: 'Diagnostic Volumes Published' },
              { num: '3', label: 'Core Work Pillars' },
              { num: 'AI', label: 'Adoption Readiness Focus' },
            ].map((s) => (
              <div class="border-l-2 border-teal-DEFAULT/40 pl-3">
                <p class="font-heading text-xl text-teal-DEFAULT font-bold leading-none">{s.num}</p>
                <p class="text-muted text-xs mt-1">{s.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Photo + credential -->
        <div class="lg:col-span-5 flex flex-col gap-4 animate-on-scroll" style="animation-delay:0.35s">

          <!-- Photo -->
          <div class="relative rounded-lg overflow-hidden border border-teal-DEFAULT/25"
               style="background: linear-gradient(135deg, #0a2540 0%, #0f172a 100%);">
            <img
              src="/images/nikki-cates.png"
              alt="Nikki Cates - CEO &amp; Founder, Strategic Transformations"
              class="w-full h-auto object-cover object-top"
              style="max-height: 420px; object-position: center top;"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
            <!-- Photo overlay tag -->
            <div class="absolute bottom-0 left-0 right-0 p-4"
                 style="background: linear-gradient(to top, rgba(15,23,42,0.92) 60%, transparent);">
              <p class="font-heading text-light text-sm font-semibold">Nikki Cates</p>
              <p class="text-teal-DEFAULT text-xs font-body font-bold uppercase tracking-widest">
                CEO &amp; Founder, Strategic Transformations
              </p>
            </div>
          </div>

          <!-- Credential pills -->
          <div class="grid grid-cols-2 gap-3">
            {[
              { icon: '🎖️', label: 'Army Veteran' },
              { icon: '✍🏾', label: 'Womanist Scholar' },
              { icon: '📖', label: 'Published Author' },
              { icon: '🌍', label: 'Keynote Speaker' },
            ].map((item) => (
              <div class="card teal-hover flex items-center gap-3 py-3 px-4">
                <span class="text-xl shrink-0">{item.icon}</span>
                <p class="font-heading text-light font-semibold text-xs">{item.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-28" style="background: linear-gradient(to bottom, transparent, #0f172a);"></div>
  </section>


  <!-- ─── MANAGEMENT LAYER ASSESSMENT ────────────────── -->
  <section class="py-16 px-4" style="background: radial-gradient(ellipse at 20% 20%, #0d2a45 0%, #06111f 60%);">
    <div class="container-wide max-w-2xl mx-auto text-center mb-10">
      <p class="text-teal-DEFAULT text-xs uppercase tracking-widest mb-3 font-bold">Free Diagnostic Tool</p>
      <h2 class="font-heading text-light text-2xl md:text-3xl mb-4 leading-snug">
        The Management Layer Assessment
      </h2>
      <p class="text-muted text-base max-w-xl mx-auto leading-relaxed">
        Seven questions. Under three minutes. Find out whether your organization is structurally positioned to lead through AI-era complexity — or whether friction is already compounding costs you haven't quantified.
      </p>
    </div>
    <div class="flex justify-center">
      <div id="mla-quiz-root" style="width:100%;max-width:660px;"></div>
    </div>
  </section>

  <!-- ─── QUIZ ENTRY POINT ─────────────────────────── -->
  <section class="py-12 bg-[#0c1525]">
    <div class="container-wide max-w-3xl mx-auto text-center">
      <p class="text-teal-DEFAULT text-xs uppercase tracking-widest mb-3 font-bold">Not sure where your organization stands?</p>
      <h2 class="font-heading text-light text-2xl md:text-3xl mb-4 leading-snug">
        Take the 3-minute AI Readiness Quiz.
      </h2>
      <p class="text-muted text-base mb-6 max-w-xl mx-auto leading-relaxed">
        Answer six questions and get a personalized profile that tells you whether the Frictionless Manager Bootcamp fits where your organization actually is right now.
      </p>
      <a href="/strategic-reset/quiz/" class="btn-teal text-base !py-3 !px-7 inline-flex">
        Start the Quiz &rarr;
      </a>
    </div>
  </section>


  <!-- ─── PAIN POINT RECOGNITION ───────────────────── -->
  <section class="py-20 bg-[#0c1525]">
    <div class="container-wide">
      <div class="max-w-2xl mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">What It Feels Like Inside</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          Mid-sized organizations are being asked to adopt AI while their people systems are already strained.
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          'Your best people are tired, talented, and quietly calculating their exit.',
          'AI adoption is moving faster than your decision rights, workflows, and leadership capacity.',
          'Middle managers are absorbing pressure from every direction without real authority to redesign the load.',
          'Executives know the strategy, but the structure underneath it keeps creating friction.',
          'Change fatigue has made every new initiative feel like another demand instead of a path forward.',
          'Engagement surveys name the symptoms, but not the hidden architecture producing them.',
          'Institutional knowledge is sitting with the same over-relied-upon people you cannot afford to lose.',
          'Teams are using AI tools unevenly, anxiously, or in ways that expose deeper role confusion.',
          'You can feel the strain before you can prove it. That is the diagnostic gap.',
        ].map((pain, i) => (
          <div class="card teal-hover flex items-start gap-3 animate-on-scroll" style={`animation-delay:${i * 0.05}s`}>
            <span class="text-teal-DEFAULT shrink-0 mt-1 text-sm">→</span>
            <p class="text-muted text-sm leading-relaxed">{pain}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center animate-on-scroll">
        <p class="font-heading text-xl text-light mb-2">If any of that landed, the issue is not resistance to change.</p>
        <p class="text-muted text-sm mb-6 max-w-lg mx-auto">
          It is structural strain. Before you deploy more technology, you need to know whether your human architecture can carry it.
        </p>
        <a href="/structural-burnout/" class="btn-teal">See How the Work Works →</a>
      </div>
    </div>
  </section>


  <!-- ─── PHOTO BREAK ───────────────────────────────── -->
  <div class="w-full h-56 md:h-72 overflow-hidden">
    <img
      src="/images/home/inclusive-workspace.jpg"
      alt="Diverse inclusive team working together in a modern open office environment"
      class="w-full h-full object-cover opacity-75"
      style="object-position: center 30%;"
      loading="lazy"
    />
  </div>

  <!-- ─── TRANSFORMATION OUTCOMES ──────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(13,148,136,0.05) 0%, transparent 65%);"></div>
    <div class="container-wide relative z-10">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">The Shift</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">What changes when you fix the design.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border max-w-4xl mx-auto rounded-lg overflow-hidden">
        {[
          { before: 'AI adoption treated as a tool rollout', after: 'AI adoption guided by structural readiness and human capacity' },
          { before: 'Best people carrying invisible overload', after: 'Load paths mapped before attrition becomes the signal' },
          { before: 'Leaders reacting to burnout after damage is done', after: 'Executives diagnosing the conditions producing burnout' },
          { before: 'Middle managers absorbing change without authority', after: 'Decision rights, responsibilities, and escalation paths clarified' },
          { before: 'Engagement data naming symptoms without action', after: 'Diagnostic findings translated into strategic advisory priorities' },
          { before: 'Initiatives competing for the same exhausted people', after: 'Transformation paced around the structure that must carry it' },
        ].map((item) => (
          <div class="bg-surface p-6 flex gap-6 items-start">
            <div class="flex-1">
              <p class="text-xs font-body font-bold uppercase tracking-widest text-red-400/70 mb-2">Before</p>
              <p class="text-muted text-sm">{item.before}</p>
            </div>
            <div class="text-teal-DEFAULT/40 text-xl shrink-0 mt-3">→</div>
            <div class="flex-1">
              <p class="text-xs font-body font-bold uppercase tracking-widest text-teal-DEFAULT mb-2">After</p>
              <p class="text-light text-sm font-medium">{item.after}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


   <!-- ─── PHOTO BREAK 2 ─────────────────────────────── -->
  <div class="w-full h-56 md:h-72 overflow-hidden">
    <img
      src="/images/bootcamp/modern-inclusive-office.jpg"
      alt="Diverse professionals working in a modern inclusive open-plan office"
      class="w-full h-full object-cover opacity-75"
      style="object-position: center 25%;"
      loading="lazy"
    />
  </div>

  <!-- ─── WHO WE SERVE / HOW WE WORK ──────────── -->
  <section class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Who We Serve</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">Built for leaders carrying both retention pressure and AI transformation.</h2>
        <p class="text-muted text-sm mt-3 max-w-md mx-auto">
          Strategic Transformations partners with mid-sized organizations that need sharper diagnosis before another initiative lands on already strained people.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
        {[
          {
            label: 'Mid-Sized Organizations',
            badge: 'Ideal Fit',
            desc: 'Teams large enough for complexity, but close enough to feel every resignation, failed handoff, and AI implementation misstep.',
          },
          {
            label: 'CNOs, COOs, and Operational Leaders',
            badge: 'Primary Buyers',
            desc: 'Executives accountable for talent sustainability, operational cadence, leadership capacity, and transformation readiness.',
          },
          {
            label: 'Executive Teams',
            badge: 'Decision Makers',
            desc: 'Leadership groups that know AI adoption, retention, and burnout cannot be solved by isolated tools, perks, or trainings.',
          },
        ].map((item) => (
          <div class="card teal-hover flex flex-col gap-3 animate-on-scroll">
            <div class="flex items-center justify-between mb-1">
              <span class="st-tag">{item.badge}</span>
            </div>
            <h3 class="font-heading text-xl font-bold text-teal-DEFAULT">{item.label}</h3>
            <p class="text-muted text-sm leading-relaxed flex-1">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-16 mb-10 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">How We Work</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">Three pillars. One diagnostic operating system.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          {
            label: 'Proprietary Diagnostics',
            desc: 'We identify the hidden structural strain affecting retention, leadership load, decision clarity, and AI readiness.',
          },
          {
            label: 'Strategic Advisory',
            desc: 'We help executives translate diagnostic findings into operational priorities, communication rhythms, and implementation choices.',
          },
          {
            label: 'Keynotes & Bootcamps',
            desc: 'We deliver group training and keynote experiences that equip leaders with the structural language and diagnostic tools to lead through AI-era complexity.',
          },
        ].map((item) => (
          <div class="card teal-hover flex flex-col gap-3 animate-on-scroll">
            <p class="font-heading text-teal-DEFAULT text-xl font-bold">{item.label}</p>
            <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── BOOTCAMP ─────────────────────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 70% at 80% 50%, rgba(13,148,136,0.06) 0%, transparent 60%);"></div>
    <div class="container-wide relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <div class="lg:col-span-2 animate-on-scroll">
          <span class="st-tag mb-5 inline-flex">Nikki's Events</span>
          <h2 class="font-heading text-3xl md:text-4xl text-light mb-5">
            Before You Deploy AI,<br/>Diagnose Your Structure.
          </h2>
          <p class="text-muted text-sm leading-relaxed mb-6">
            A bootcamp for individual leaders and organizational attendees who need to understand
            the human architecture AI will land on before implementation begins.
          </p>
          <p class="font-body text-sm mb-6">
            <span class="text-teal-DEFAULT font-semibold">Designed for readiness.</span>
            <span class="text-muted"> Participants learn to spot structural strain, role confusion, decision-rights gaps, and adoption friction before they become expensive.</span>
          </p>
          <a href="/structural-burnout/briefing" class="btn-teal !text-sm">
            Join the Waitlist →
          </a>
        </div>

        <div class="lg:col-span-3 space-y-3 animate-on-scroll" style="animation-delay:0.15s">
          {[
            { num: '01', title: 'Diagnose where AI will amplify existing strain', tag: 'Readiness' },
            { num: '02', title: 'Map the people, process, and authority gaps hidden beneath adoption plans', tag: 'Structure' },
            { num: '03', title: 'Identify which leaders and teams are carrying unsustainable load', tag: 'Retention' },
            { num: '04', title: 'Build better questions before technology decisions become culture problems', tag: 'Implementation' },
          ].map((item) => (
            <div class="flex items-center gap-4 card teal-hover py-4 px-5 group">
              <span class="font-heading text-3xl text-teal-DEFAULT/20 font-bold leading-none shrink-0">{item.num}</span>
              <p class="font-heading text-light text-sm font-semibold flex-1">{item.title}</p>
              <span class="st-tag text-xs shrink-0 hidden md:inline-flex">{item.tag}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ─── ORGANIZATIONAL WORKSHOP ──────────────────── -->
  <section class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div class="animate-on-scroll">
          <span class="st-tag mb-5 inline-flex">Workshop for Organizations</span>
          <h2 class="font-heading text-3xl md:text-5xl text-light mb-5">
            Before You Deploy AI,<br/><span class="text-teal-DEFAULT">Diagnose Your Structure.</span>
          </h2>
          <p class="text-muted leading-relaxed mb-4">
            Bring Nikki into your organization for an executive-facing workshop that helps leaders
            identify the structural strain AI adoption could amplify.
          </p>
          <p class="text-muted leading-relaxed mb-8">
            The same value proposition, applied inside your context: helping your best people stay,
            helping leaders make cleaner decisions, and helping AI adoption move with less friction.
          </p>
          <a href="/structural-burnout/briefing" class="btn-teal">Request Executive Briefing →</a>
        </div>

        <div class="space-y-3 animate-on-scroll" style="animation-delay:0.2s">
          {[
            { letter: '1', name: 'Pre-Implementation Diagnosis', desc: 'Surface the organizational conditions that could turn AI adoption into more overload, confusion, or attrition.' },
            { letter: '2', name: 'Leadership Load Mapping', desc: 'Identify where pressure is concentrating and which roles are being asked to absorb unsupported change.' },
            { letter: '3', name: 'Decision-Rights Clarity', desc: 'Name the ownership, approval, and accountability gaps that create adoption friction.' },
            { letter: '4', name: 'Retention-Focused Readiness', desc: 'Translate the findings into questions, priorities, and next steps leaders can use before deployment.' },
          ].map((p) => (
            <div class="flex items-start gap-4 p-4 rounded-md border border-border hover:border-teal-DEFAULT/30 transition-colors bg-surface/50">
              <span class="font-heading text-teal-DEFAULT text-2xl font-bold w-7 shrink-0">{p.letter}</span>
              <div>
                <p class="font-heading text-light font-semibold text-sm mb-1">{p.name}</p>
                <p class="text-muted text-xs leading-relaxed">{p.desc}</p>
              </div>
            </div>
          ))}
          <!-- Entry diagnostic -->
          <div class="p-4 rounded-md border border-teal-DEFAULT/30 bg-teal-DEFAULT/5">
            <p class="font-body text-xs font-bold uppercase tracking-widest text-teal-DEFAULT mb-1">AI Recalibration Workshop</p>
            <p class="text-light text-sm font-semibold">How to Uncover the Hidden Structural Strain in Preparation for the AI Implementation Era</p>
            <p class="text-muted text-xs mt-1">Available as a workshop, briefing, or executive team session.</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── MEET NIKKI ────────────────────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 60% at 20% 50%, rgba(13,148,136,0.05) 0%, transparent 65%);"></div>
    <div class="container-wide relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5 animate-on-scroll">
          <div class="relative rounded-lg overflow-hidden border border-teal-DEFAULT/25 bg-surface">
            <img
              src="/images/nikki-cates-purple.jpg"
              alt="Nikki Cates, CEO and Founder of Strategic Transformations"
              class="w-full h-auto object-cover object-top"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <div class="lg:col-span-7 animate-on-scroll" style="animation-delay:0.15s">
          <span class="st-tag mb-5 inline-flex">Meet Nikki</span>
          <h2 class="font-heading text-3xl md:text-5xl text-light mb-5">
            Nikki Cates,<br/><span class="text-teal-DEFAULT">CEO &amp; Founder</span>
          </h2>
          <p class="text-muted leading-relaxed mb-4">
            Nikki Cates is the founder of Strategic Transformations and the creator of the UNMASK
            diagnostic architecture. Her work helps organizations name the structural conditions
            producing burnout, attrition, leadership overload, and adoption friction.
          </p>
          <p class="text-muted leading-relaxed mb-8">
            She brings a rare blend of operational practice, womanist scholarship, veteran leadership,
            published frameworks, and executive advisory experience to organizations navigating the
            AI implementation era.
          </p>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            {[
              'Army Veteran',
              'Womanist Scholar',
              'Published Author',
              'AI-Era Strategist',
            ].map((credential) => (
              <div class="card teal-hover py-3 px-4">
                <p class="font-heading text-light font-semibold text-xs">{credential}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── URI CALLOUT ───────────────────────────────── -->
  <section class="section-pad bg-[#0c1525] relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 70% at 20% 50%, rgba(107,33,168,0.09) 0%, transparent 60%), radial-gradient(ellipse 40% 50% at 80% 30%, rgba(217,119,6,0.06) 0%, transparent 55%);"></div>
    <div class="container-mid relative z-10 animate-on-scroll">
      <div class="border border-plum-DEFAULT/30 rounded-lg p-10 md:p-14 bg-[#1a0a2e]/40 text-center">
        <div class="flex items-start justify-center gap-5 mb-6">
          <img src="/logos/uri-logo.png" alt="URI" width="180" height="41" class="h-18 w-auto" loading="lazy" />
        </div>
        <h2 class="font-heading text-3xl md:text-4xl text-light mb-4">
          Liberation is the<br/>
          <span class="text-gold">theological work</span> of leadership.
        </h2>
        <p class="text-muted leading-relaxed mb-8 max-w-xl mx-auto">
          Unbothered Resistance International is the justice-centered formation and research wing
          beneath everything Nikki builds. Rooted in womanist theology, structural analysis, and
          a commitment to restoring right relationships, in organizations, communities, and Spirit.
        </p>
        <a href="/uri/" class="btn-gold">Explore URI Formation →</a>
      </div>
    </div>
  </section>


  <!-- ─── SRI CALLOUT ────────────────────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 70% at 80% 50%, rgba(13,148,136,0.08) 0%, transparent 60%);"></div>
    <div class="container-wide relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div class="animate-on-scroll">
          <span class="st-tag mb-5 inline-flex">Strategic Reset Intensive</span>
          <h2 class="font-heading text-3xl md:text-4xl text-light mb-5">
