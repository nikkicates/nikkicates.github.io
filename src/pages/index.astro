`;

  const style = document.createElement('style');
  style.textContent = css;
  document.head.appendChild(style);

  const html = `
<div class="mla-card">
  <div class="mla-hdr">
    <div class="mla-slabel">Strategic Transformations · Management Diagnostic</div>
    <div class="mla-mtitle">The Management Layer Assessment</div>
    <div class="mla-stitle" id="mla-subtitle">Diagnose structural friction before it becomes a crisis</div>
  </div>
  <div class="mla-pbar"><div class="mla-pfill" id="mla-pfill"></div></div>
  <div class="mla-screen active mla-fin" id="mla-screen-intro">
    <div class="mla-ibody">
      <p class="mla-itext">Structural burnout does not announce itself. It accumulates — in the gaps between what your managers are asked to carry and what your organization actually supports.</p>
      <p class="mla-itext">This diagnostic assesses seven dimensions of your management layer in under three minutes. Your results reveal whether your organization is structurally positioned to lead through AI-era complexity — or whether friction is already compounding costs you have not yet quantified.</p>
      <div class="mla-imeta">
        <span class="mla-imt">7 questions</span>
        <span class="mla-imt">Under 3 minutes</span>
        <span class="mla-imt">Personalized results</span>
      </div>
      <button class="mla-sbtn" id="mla-start-btn">Begin the Diagnostic →</button>
    </div>
  </div>
  <div class="mla-screen" id="mla-screen-questions">
    <div class="mla-qbody">
      <div class="mla-qmeta">
        <span class="mla-qnum" id="mla-q-num"></span>
        <span class="mla-qcat" id="mla-q-cat"></span>
        <span class="mla-qicon" id="mla-q-icon"></span>
      </div>
      <div class="mla-qtext" id="mla-q-text"></div>
      <div class="mla-agrid" id="mla-answer-grid"></div>
    </div>
  </div>
  <div class="mla-screen" id="mla-screen-capture"><div class="mla-ibody"><div class="mla-slabel" style="color:#0d9488;margin-bottom:12px">Almost There</div><p class="mla-mtitle" style="font-size:18px;line-height:1.4;margin-bottom:10px">Enter your name and email to reveal your Management Layer Assessment results.</p><p class="mla-stitle" style="margin-bottom:20px">No spam. Used only to deliver your results and relevant updates.</p><form id="mla-capture-form"><div style="margin-bottom:10px"><input type="text" id="mla-cap-name" placeholder="First Name" required style="width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.15);border-radius:8px;padding:12px 16px;color:#f8fafc;font-family:'DM Sans',sans-serif;font-size:13px;outline:none;box-sizing:border-box"/></div><div style="margin-bottom:16px"><input type="email" id="mla-cap-email" placeholder="Email Address" required style="width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.15);border-radius:8px;padding:12px 16px;color:#f8fafc;font-family:'DM Sans',sans-serif;font-size:13px;outline:none;box-sizing:border-box"/></div><button type="submit" class="mla-sbtn">Reveal My Results →</button></form></div></div><div class="mla-screen" id="mla-screen-results">
    <div class="mla-rhdr">
      <div class="mla-rrow">
        <div style="flex:1">
          <div class="mla-rcat-lbl" id="mla-r-label">YOUR RESULT</div>
          <div class="mla-rlvl" id="mla-r-level"></div>
          <div class="mla-rhl" id="mla-r-headline"></div>
        </div>
        <div class="mla-sring" id="mla-score-ring">
          <span class="mla-snum" id="mla-score-num"></span>
          <span class="mla-slb">SCORE</span>
        </div>
      </div>
    </div>
    <div class="mla-bdown">
      <div class="mla-blbl">DIMENSION BREAKDOWN</div>
      <div id="mla-breakdown"></div>
    </div>
    <div class="mla-rins">
      <div class="mla-inslbl">STRATEGIC INSIGHT</div>
      <div class="mla-instxt" id="mla-r-insight"></div>
    </div>
    <div class="mla-ctablock">
      <div class="mla-ctatxt" id="mla-r-cta"></div>
      <div class="mla-ctabtns">
        <button class="mla-ctap" id="mla-cta-primary">Learn About the Bootcamp →</button>
        <button class="mla-ctas" id="mla-retake-btn">Retake Assessment</button>
      </div>
    </div>
    <div class="mla-ftr">
      <span class="mla-ftxt" style="color:var(--mla-teal);font-weight:600">Strategic Transformations</span>
      <span class="mla-ftxt">nikki@strategicunmasking.com</span>
    </div>
  </div>
</div>`;

  const root = document.getElementById('mla-quiz-root');
  if (!root) return;
  root.innerHTML = html;

  const questions = [
    {id:1,category:"AUTHORITY",icon:"⚖",text:"My managers have decision-making authority that matches the level of responsibility they carry.",weight:2},
    {id:2,category:"AI READINESS",icon:"◈",text:"My organization has provided structured leadership development support specifically for navigating AI-era complexity.",weight:2},
    {id:3,category:"FRICTION",icon:"⚡",text:"I can clearly identify where friction is concentrating in my management layer right now.",weight:1},
    {id:4,category:"CAPACITY",icon:"◎",text:"My managers spend the majority of their time on human leadership — not administrative compliance and reporting.",weight:2},
    {id:5,category:"EQUITY",icon:"❋",text:"My organization actively accounts for the invisible labor carried by marginalized managers in performance evaluation.",weight:1},
    {id:6,category:"CULTURE",icon:"◉",text:"My managers feel psychologically safe enough to tell leadership the truth about what the organization is costing them.",weight:2},
    {id:7,category:"INVESTMENT",icon:"◆",text:"Our current investment in management development is proportional to what we are asking our managers to carry.",weight:2},
  ];
  const opts = [
    {label:"Strongly Agree",value:4,color:"#58bbc2"},
    {label:"Agree",value:3,color:"#3a9ab0"},
    {label:"Somewhat",value:2,color:"#2a7ca3"},
    {label:"Disagree",value:1,color:"#31245a"},
    {label:"Not at All",value:0,color:"#6b2a8a"},
  ];
  const results = [
    {min:80,level:"Structurally Sound",color:"#58bbc2",headline:"Your management layer has strong foundational support.",insight:"You have built intentional infrastructure around your managers. The next opportunity is deepening recalibration capacity so your organization stays ahead of AI-era complexity rather than reacting to it.",cta:"The Frictionless Manager Bootcamp will sharpen what you have already built."},
    {min:60,level:"Friction Present",color:"#2a7ca3",headline:"Structural gaps are generating visible and invisible costs.",insight:"Your managers are carrying more than your current systems account for. The gap between their responsibility and their support is costing you in attrition, productivity, and culture — even if the numbers have not caught up yet.",cta:"The Frictionless Manager Bootcamp was built precisely for organizations at this inflection point."},
    {min:40,level:"Critical Gaps",color:"#ac6dbf",headline:"Your management layer is under significant structural stress.",insight:"The conditions you have identified are not a people problem — they are an organizational design problem. Without intervention, the friction will compound into retention crisis, culture erosion, and leadership failure at the exact moments you need your managers most.",cta:"The Frictionless Manager Bootcamp Founding Cohort is your most direct path to structural recalibration. Early October 2026."},
    {min:0,level:"Under Pressure",color:"#e05c8a",headline:"Your management layer needs structural intervention now.",insight:"What you are experiencing is not a management failure — it is a system that was never designed to support the leaders you are asking to carry it. The cost of not addressing this is already appearing in your organization.",cta:"Connect with Strategic Transformations directly. The Founding Cohort launches early October 2026 with limited seats."},
  ];

  let current = 0, answers = {};
  const maxScore = questions.reduce((s,q)=>s+q.weight*4,0);

  function showScreen(id) {
    document.querySelectorAll('.mla-screen').forEach(s=>s.classList.remove('active'));
    const el = document.getElementById('mla-screen-'+id);
    el.classList.add('active');
    el.classList.remove('mla-fin');
    void el.offsetWidth;
    el.classList.add('mla-fin');
  }

  function startAssessment() {
    current=0; answers={};
    document.getElementById('mla-subtitle').textContent='Question 1 of '+questions.length;
    renderQuestion();
    showScreen('questions');
  }

  function renderQuestion() {
    const q=questions[current];
    document.getElementById('mla-pfill').style.width=(current/questions.length*100)+'%';
    document.getElementById('mla-q-num').textContent=String(current+1).padStart(2,'0')+' / '+String(questions.length).padStart(2,'0');
    document.getElementById('mla-q-cat').textContent=q.category;
    document.getElementById('mla-q-icon').textContent=q.icon;
    document.getElementById('mla-q-text').textContent=q.text;
    document.getElementById('mla-subtitle').textContent='Question '+(current+1)+' of '+questions.length;
    const grid=document.getElementById('mla-answer-grid');
    grid.innerHTML='';
    opts.forEach(opt=>{
      const btn=document.createElement('button');
      btn.className='mla-abtn';
      btn.innerHTML=`<div class="mla-adot" style="background:${opt.color}"></div><span class="mla-albl">${opt.label}</span>`;
      btn.addEventListener('click',()=>handleAnswer(opt.value,opt.label));
      grid.appendChild(btn);
    });
  }

  function handleAnswer(val,label) {
    document.querySelectorAll('.mla-abtn').forEach(b=>b.disabled=true);
    opts.forEach((opt,i)=>{if(opt.value===val)document.querySelectorAll('.mla-abtn')[i].classList.add('selected');});
    answers[questions[current].id]={value:val,label};
    setTimeout(()=>{
      if(current<questions.length-1){current++;renderQuestion();}
      else showScreen('capture');
    },500);
  }

  function showResults() {
    document.getElementById('mla-pfill').style.width='100%';
    document.getElementById('mla-subtitle').textContent='Your Diagnostic Results';
    const score=Object.entries(answers).reduce((s,[id,a])=>{
      const q=questions.find(q=>q.id===parseInt(id));
      return s+(q?a.value*q.weight:0);
    },0);
    const pct=Math.round((score/maxScore)*100);
    const result=results.find(r=>pct>=r.min);
    document.getElementById('mla-r-label').style.color=result.color;
    document.getElementById('mla-r-level').textContent=result.level;
    document.getElementById('mla-r-level').style.color=result.color;
    document.getElementById('mla-r-headline').textContent=result.headline;
    document.getElementById('mla-r-insight').textContent=result.insight;
    document.getElementById('mla-r-cta').textContent=result.cta;
    document.getElementById('mla-score-num').textContent=pct;
    document.getElementById('mla-score-num').style.color=result.color;
    const ring=document.getElementById('mla-score-ring');
    ring.style.borderColor=result.color;
    ring.querySelector('.mla-slb').style.color=result.color;
    const bd=document.getElementById('mla-breakdown');
    bd.innerHTML='';
    questions.forEach(q=>{
      const ans=answers[q.id];
      const v=ans?ans.value:0;
      const lbl=ans?ans.label:'—';
      const p=(v/4)*100;
      const bc=p>=75?'#58bbc2':p>=50?'#2a7ca3':p>=25?'#ac6dbf':'#e05c8a';
      bd.innerHTML+=`<div class="mla-brow"><div class="mla-bcat">${q.category}</div><div class="mla-bbg"><div class="mla-bfill" style="width:0%;background:${bc}" data-w="${p}"></div></div><div class="mla-bval" style="color:${bc}">${lbl}</div></div>`;
    });
    showScreen('results');
    setTimeout(()=>{document.querySelectorAll('.mla-bfill').forEach(f=>{f.style.width=f.dataset.w+'%';});},200);
  }

  function resetAssessment() {
    current=0;answers={};
    document.getElementById('mla-pfill').style.width='0%';
    document.getElementById('mla-subtitle').textContent='Diagnose structural friction before it becomes a crisis';
    showScreen('intro');
  }

  document.getElementById('mla-capture-form').addEventListener('submit',function(e){e.preventDefault();var n=document.getElementById('mla-cap-name').value.trim();var em=document.getElementById('mla-cap-email').value.trim();if(!n||!em)return;var sc=Object.entries(answers).reduce(function(s,arr){var q=questions.find(function(q){return q.id===parseInt(arr[0]);});return s+(q?arr[1].value*q.weight:0);},0);var pct=Math.round((sc/maxScore)*100);var res=results.find(function(r){return pct>=r.min;});fetch('https://services.leadconnectorhq.com/hooks/35XiTsvy0Kt7TRNBabas/webhook-trigger/31ac4629-043a-4bcf-9a1a-2027bec82f32',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:n,email:em,source:'Management Layer Assessment',score:pct,result_level:res?res.level:'unknown',submitted_at:new Date().toISOString(),page_url:window.location.href})}).catch(function(){});showResults();});document.getElementById('mla-start-btn').addEventListener('click',startAssessment);
  document.getElementById('mla-retake-btn').addEventListener('click',resetAssessment);
  document.getElementById('mla-cta-primary').addEventListener('click',()=>window.open('https://strategictransformations.net','_blank'));
})();
</script>
