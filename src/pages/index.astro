---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-zinc-950 text-zinc-100 flex flex-col items-center justify-center px-6 text-center">
    <h1 class="text-6xl md:text-7xl font-bold tracking-tighter mb-6">
      Nikki Cates
    </h1>
    
    <p class="text-2xl text-zinc-400 max-w-lg mb-12">
      One home for Structural Burnout, Ops, Leadership & Tools
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/structural-burnout" class="px-10 py-5 bg-white text-black font-semibold rounded-2xl hover:bg-zinc-200 transition">
        Structural Burnout
      </a>
      <a href="/ops" class="px-10 py-5 border border-zinc-700 text-white font-semibold rounded-2xl hover:bg-zinc-900 transition">
        Ops Hub
      </a>
    </div>
  </div>
</Layout>