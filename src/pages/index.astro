---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Nikki Cates — Structural Recalibration Strategist"
  description="Nikki Cates helps executives and organizations dismantle the structural conditions that create burnout — before they burn out the people holding everything together."
  section="home"
  accentColor="teal"
>

  <!-- ─── HERO ─────────────────────────────────────── -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden">
    <!-- Background gradient + noise -->
    <div class="absolute inset-0 bg-[#0f172a]"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 60% 50%, rgba(13,148,136,0.09) 0%, transparent 70%), radial-gradient(ellipse 50% 50% at 10% 80%, rgba(15,76,122,0.12) 0%, transparent 60%);"></div>

    <!-- Decorative vertical line -->
    <div class="absolute left-0 top-0 bottom-0 w-[3px]" style="background: linear-gradient(to bottom, transparent, #0d9488 30%, #0d9488 70%, transparent);"></div>

    <div class="container-wide relative z-10 py-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">

        <!-- Left: Text -->
        <div class="lg:col-span-7">
          <div class="st-tag mb-6 animate-on-scroll">
            <svg width="8" height="8" viewBox="0 0 8 8" fill="currentColor"><circle cx="4" cy="4" r="4"/></svg>
            AI-Era Organizational Strategist
          </div>

          <h1 class="font-heading text-5xl md:text-6xl xl:text-7xl text-light font-bold leading-[1.08] mb-6 animate-on-scroll" style="animation-delay:0.1s">
            Burnout<br/>
            <em class="not-italic text-teal-DEFAULT">is a Design</em><br/>
            Flaw.
          </h1>

          <p class="font-body text-lg text-muted leading-relaxed mb-4 max-w-xl animate-on-scroll" style="animation-delay:0.2s">
            Organizations don't burn out people. <strong class="text-light">Structures do.</strong>
            Nikki Cates is the Structural Recalibration Strategist who helps executives, boards, and leadership teams
            diagnose and dismantle the hidden architectures driving attrition, silenced talent, and systemic exhaustion.
          </p>
          <p class="font-body text-base text-muted mb-10 max-w-xl animate-on-scroll" style="animation-delay:0.25s">
            Army veteran. Womanist theologian. Creator of the <span class="text-teal-DEFAULT font-semibold">UNMASK Framework</span>.
            Author. Speaker. Founder of Strategic Transformations &amp; URI.
          </p>

          <div class="flex flex-wrap gap-4 animate-on-scroll" style="animation-delay:0.3s">
            <a href="/structural-burnout/briefing" class="btn-teal">
              Request Executive Briefing
              <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
            <a href="/structural-burnout/" class="btn-outline-teal">
              Explore the Work
            </a>
          </div>
        </div>

        <!-- Right: Credential tiles -->
        <div class="lg:col-span-5 grid grid-cols-2 gap-4 animate-on-scroll" style="animation-delay:0.4s">
          {[
            { icon: '⚡', label: 'UNMASK Framework', sub: 'Proprietary Diagnostic System' },
            { icon: '🎖️', label: 'Army Veteran', sub: 'Leadership Under Pressure' },
            { icon: '📚', label: 'Graduate Scholar', sub: 'Womanist Theology & Ethics' },
            { icon: '🌍', label: 'Global Speaker', sub: 'Keynotes from $12,500' },
          ].map((item) => (
            <div class="card teal-hover p-5">
              <div class="text-2xl mb-2">{item.icon}</div>
              <p class="font-heading text-sm font-semibold text-light">{item.label}</p>
              <p class="text-xs text-muted mt-1">{item.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to bottom, transparent, #0f172a);"></div>
  </section>


  <!-- ─── ENTRY POINTS ──────────────────────────────── -->
  <section class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="text-center mb-14 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Navigate the Ecosystem</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          Where do you need to go?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          {
            href: '/structural-burnout/',
            icon: '🏗️',
            accent: 'teal',
            label: 'Structural Burnout',
            desc: 'The diagnostic framework for organizations burning through talent. Diagnose the design, not the people.',
            cta: 'Enter the Hub →',
          },
          {
            href: '/uri/',
            icon: '✊🏾',
            accent: 'gold',
            label: 'URI Formation',
            desc: 'Justice-centered leadership formation at the intersection of womanist theology, structural analysis, and liberation.',
            cta: 'Enter Formation →',
          },
          {
            href: '/structural-burnout/services',
            icon: '📊',
            accent: 'teal',
            label: 'Services & Pricing',
            desc: 'From diagnostic architecture to 90-day recalibration. All engagements begin with a vetting conversation.',
            cta: 'View Services →',
          },
          {
            href: '/structural-burnout/briefing',
            icon: '📋',
            accent: 'teal',
            label: 'Executive Briefing',
            desc: 'This is a protected entry. Request a briefing to begin the vetting process for high-commitment engagements.',
            cta: 'Request Briefing →',
          },
          {
            href: '/structural-burnout/pitch',
            icon: '💼',
            accent: 'teal',
            label: 'Investor Hub',
            desc: 'Strategic Transformations is scaling. Review the investment thesis, traction, and seed capital opportunity.',
            cta: 'View Pitch →',
          },
          {
            href: '/books/',
            icon: '📖',
            accent: 'teal',
            label: 'UNMASK Blueprint Series',
            desc: 'Institutional-grade diagnostic workbooks. Vol. 1 & 2 available now. Built for teams, leaders, and practitioners.',
            cta: 'View Books →',
          },
          {
            href: '/structural-burnout/nexus',
            icon: '🪪',
            accent: 'teal',
            label: 'Nexus Card',
            desc: 'Digital networking card. QR-ready. All vetted entry points in one place for conference and event connections.',
            cta: 'View Card →',
          },
          {
            href: '/mogul-ops/',
            icon: '🔐',
            accent: 'teal',
            label: 'Mogul Ops Portal',
            desc: 'Internal operations portal for team and systems access. Authorized personnel only.',
            cta: 'Access Portal →',
          },
        ].map((item) => (
          <a
            href={item.href}
            class={`card ${item.accent === 'gold' ? 'gold-hover' : 'teal-hover'} flex flex-col gap-3 group no-underline animate-on-scroll`}
          >
            <span class="text-3xl">{item.icon}</span>
            <h3 class={`font-heading text-lg font-semibold ${item.accent === 'gold' ? 'text-gold' : 'text-teal-DEFAULT'}`}>
              {item.label}
            </h3>
            <p class="text-muted text-sm leading-relaxed flex-1">{item.desc}</p>
            <span class={`text-xs font-body font-700 uppercase tracking-widest ${item.accent === 'gold' ? 'text-gold' : 'text-teal-DEFAULT'} mt-2 group-hover:translate-x-1 inline-block transition-transform`}>
              {item.cta}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── UNMASK SERIES CALLOUT ─────────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(13,148,136,0.07) 0%, transparent 65%);"></div>
    <div class="container-mid relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-14 items-center">
        <div class="animate-on-scroll">
          <span class="st-tag mb-5 inline-flex">Signature Publication</span>
          <h2 class="font-heading text-4xl md:text-5xl text-light mb-5">
            The <span class="text-teal-DEFAULT">UNMASK</span><br/>Blueprint Series
          </h2>
          <p class="text-muted leading-relaxed mb-4">
            These aren't self-help books. They're operational diagnostic frameworks written for the leaders, consultants,
            and organizational architects who are done treating symptoms.
          </p>
          <p class="text-muted leading-relaxed mb-8">
            <span class="text-light font-semibold">Vol. 1</span> unpacks the UNMASK Framework. <span class="text-light font-semibold">Vol. 2</span> is
            the institutional manual — built for teams, licensing, and deployment at scale.
          </p>
          <a href="/books/" class="btn-teal">
            Access the Series →
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4 animate-on-scroll" style="animation-delay:0.2s">
          {['U — Uncovering Hidden Strain', 'N — Naming the Architecture', 'M — Mapping Impact Zones', 'A — Aligning Structures', 'S — Sustaining Recalibration', 'K — Keeping Watch'].map((item, i) => (
            <div class="bg-surface border border-border rounded-md p-4">
              <span class="font-heading text-teal-DEFAULT text-xl font-bold block mb-1">
                {item.split(' — ')[0]}
              </span>
              <span class="text-xs text-muted">{item.split(' — ')[1]}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ─── SIGNATURE TALKS ───────────────────────────── -->
  <section class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Speaking</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">2026 Signature Talks</h2>
        <p class="text-muted mt-3 max-w-lg mx-auto text-sm">
          Five distinct keynotes. One through line: your organization's survival depends on what you're willing to examine.
          Speaking engagements from <span class="text-teal-DEFAULT font-semibold">starting at $12,500</span>.
        </p>
      </div>

      <div class="space-y-3 max-w-3xl mx-auto">
        {[
          'Stop the Strain Transfer',
          'Your Leadership Pipeline Is Leaking',
          'False Urgency: How "Everything Is Critical" Is Destroying Your Organization',
          'Sovereign Power: Leading Without Running on Empty',
          'When AI Breaks the Bridge: Protecting Human Architecture in the Age of Automation',
        ].map((talk, i) => (
          <div class="flex items-start gap-4 card teal-hover p-5 animate-on-scroll">
            <span class="font-heading text-3xl text-teal-DEFAULT/30 font-bold leading-none mt-1 shrink-0">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <p class="font-heading text-base font-semibold text-light">"{talk}"</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10 animate-on-scroll">
        <a href="/structural-burnout/briefing" class="btn-teal">
          Inquire About Speaking →
        </a>
      </div>
    </div>
  </section>


  <!-- ─── URI CALLOUT ───────────────────────────────── -->
  <section class="section-pad relative overflow-hidden">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 70% at 20% 50%, rgba(107,33,168,0.1) 0%, transparent 65%), radial-gradient(ellipse 40% 50% at 80% 30%, rgba(217,119,6,0.07) 0%, transparent 60%);"></div>
    <div class="container-mid relative z-10">
      <div class="border border-plum-DEFAULT/30 rounded-lg p-10 md:p-14 bg-[#1a0a2e]/40 animate-on-scroll">
        <span class="uri-tag mb-6 inline-flex">URI Formation</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light mb-4">
          Liberation is the<br/>
          <span class="text-gold">theological work</span> of leadership.
        </h2>
        <p class="text-muted leading-relaxed mb-8 max-w-xl">
          Unbothered Resistance International (URI) is the justice-centered formation and research wing undergirding
          everything Nikki Cates builds. Rooted in womanist theology, structural analysis, and a commitment to restoring
          right relationships — in organizations, communities, and Spirit.
        </p>
        <a href="/uri/" class="btn-gold">
          Explore URI Formation →
        </a>
      </div>
    </div>
  </section>


  <!-- ─── AUTHORITY STRIP ───────────────────────────── -->
  <section class="py-10 bg-surface border-y border-border">
    <div class="container-wide">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 items-center">
        {[
          'Army Veteran',
          'UNMASK Framework Creator',
          'Womanist Theologian',
          'Structural Burnout Specialist',
          'AI-Era Organizational Strategist',
          'Published Author',
        ].map((item) => (
          <span class="font-body text-xs font-700 uppercase tracking-widest text-muted">
            {item}
          </span>
        ))}
      </div>
    </div>
  </section>

</Layout>
