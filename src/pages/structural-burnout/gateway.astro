---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="bg-zinc-950 text-zinc-100 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <a href="/structural-burnout" class="inline-flex items-center gap-2 text-teal-400 hover:text-teal-300 mb-12 text-sm">
        ← Back to Structural Burnout
      </a>

      <h1 class="text-5xl md:text-6xl font-bold tracking-tighter mb-10">
        Welcome, Leader.<br>
        <span class="text-teal-400">The Recalibration Starts Here.</span>
      </h1>

      <div class="flex flex-col sm:flex-row gap-6 justify-center mt-16">
        <a href="/structural-burnout/briefing" 
           class="px-12 py-6 bg-teal-400 hover:bg-teal-300 text-zinc-950 font-semibold rounded-3xl text-lg">
          Request Executive Briefing
        </a>
        <a href="/structural-burnout/services" 
           class="px-12 py-6 border border-zinc-700 hover:border-teal-400 font-semibold rounded-3xl text-lg">
          View Solutions Catalog
        </a>
      </div>
    </div>
  </div>
</Layout>