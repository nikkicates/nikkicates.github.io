---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="bg-zinc-950 text-zinc-100 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 py-20">
      <!-- Back link -->
      <a href="/structural-burnout" class="inline-flex items-center gap-2 text-teal-400 hover:text-teal-300 mb-12 text-sm">
        ← Back to Structural Burnout
      </a>

      <!-- Hero / Invitation -->
      <div class="text-center mb-20">
        <div class="inline-block px-6 py-2.5 rounded-full bg-zinc-900 border border-teal-400/30 text-teal-400 text-xs font-bold uppercase tracking-widest mb-10">
          Invitational Diagnostic Series
        </div>

        <h1 class="text-5xl md:text-7xl font-bold tracking-tighter leading-none mb-10">
          Identify the<br/>
          <span class="text-teal-400">Invisible Extraction.</span>
        </h1>

        <p class="text-2xl text-zinc-400 max-w-3xl mx-auto leading-relaxed">
          "Your organization is likely extracting invisible labor from leaders while denying them the authority to fix the problems they are responsible for."
        </p>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-20">
        <a href="https://calendar.google.com/appointments/schedules/AcZssZ0wzeoxprLGxanzVAEMZB_aBMMuQycSnCwYHy3gsd1R3wpmUCMIHmegk-UbZzU2nRZb_XiI_I3o" 
           target="_blank"
           class="px-12 py-6 bg-teal-400 hover:bg-teal-300 text-zinc-950 font-bold rounded-2xl text-lg transition text-center">
          Request Invitation to Next Briefing
        </a>
        
        <a href="/structural-burnout/services" 
           class="px-12 py-6 border border-zinc-700 hover:border-teal-400 text-white font-bold rounded-2xl text-lg transition text-center">
          View Full Solutions Catalog
        </a>
      </div>

      <!-- Strategic Pathways -->
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Investor Path -->
        <a href="/structural-burnout/pitch" 
           class="bg-zinc-900 border border-zinc-800 hover:border-purple-400/50 rounded-3xl p-10 transition group">
          <div class="text-purple-400 text-xs font-bold uppercase tracking-widest mb-4">Strategic Thesis</div>
          <h3 class="text-3xl font-bold mb-6 group-hover:text-teal-400 transition">Investor Briefing Hub</h3>
          <p class="text-zinc-400">Review the executive case for structural recalibration and the $30k seed opportunity for the UNMASK Engine.</p>
          <div class="mt-8 text-sm text-purple-400 group-hover:text-purple-300 transition">View Full Investor Deck →</div>
        </a>

        <!-- Solutions Path -->
        <a href="/structural-burnout/services" 
           class="bg-zinc-900 border border-zinc-800 hover:border-teal-400/50 rounded-3xl p-10 transition group">
          <div class="text-teal-400 text-xs font-bold uppercase tracking-widest mb-4">Implementation</div>
          <h3 class="text-3xl font-bold mb-6 group-hover:text-teal-400 transition">Solutions Catalog</h3>
          <p class="text-zinc-400">Explore the 4-tier engagement ladder — from keynotes to full enterprise architectural redesign.</p>
          <div class="mt-8 text-sm text-teal-400 group-hover:text-teal-300 transition">View Engagement Menu →</div>
        </a>
      </div>

      <!-- Research Vault Teaser -->
      <div class="mt-24 text-center">
        <h2 class="text-3xl font-bold tracking-tighter mb-4">The Research Vault</h2>
        <p class="text-zinc-400 max-w-md mx-auto">Evidence-based research and tactical blueprints for institutional resilience in the age of AI.</p>
      </div>
    </div>
  </div>
</Layout>