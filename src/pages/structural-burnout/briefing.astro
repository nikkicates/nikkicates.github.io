---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="bg-zinc-950 text-zinc-100 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 py-20">
      <a href="/structural-burnout" class="inline-flex items-center gap-2 text-teal-400 hover:text-teal-300 mb-12 text-sm">
        ← Back to Structural Burnout
      </a>

      <h1 class="text-5xl md:text-6xl font-bold tracking-tighter leading-none mb-10">
        Structural Leadership<br>
        <span class="text-teal-400">Diagnostic</span>
      </h1>

      <p class="text-xl text-zinc-400 max-w-2xl mb-16">
        Identify exactly where your organization is leaking capacity and authority.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-3xl">
          <h3 class="text-2xl font-semibold mb-6">The Authority Gap</h3>
          <p class="text-zinc-400">Leaders held accountable for outcomes they lack authority to fix.</p>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-3xl">
          <h3 class="text-2xl font-semibold mb-6">Strain Transfer</h3>
          <p class="text-zinc-400">Invisible labor extraction from high-capacity individuals.</p>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-3xl">
          <h3 class="text-2xl font-semibold mb-6">AI Acceleration Risk</h3>
          <p class="text-zinc-400">Cracked structures multiplied 10× by AI.</p>
        </div>
      </div>

      <div class="mt-20 text-center">
        <a href="/structural-burnout/services" 
           class="inline-block px-12 py-6 bg-teal-400 hover:bg-teal-300 text-zinc-950 font-semibold rounded-3xl">
          View Full Solutions
        </a>
      </div>
    </div>
  </div>
</Layout>