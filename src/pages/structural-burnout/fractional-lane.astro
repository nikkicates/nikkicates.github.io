<script>
  // ── TIER SELECTION UI ──────────────────────────────────────────────────────
  const tierRadios = document.querySelectorAll('.tier-radio') as NodeListOf<HTMLInputElement>;
  const tierOptions = document.querySelectorAll('.tier-option') as NodeListOf<HTMLElement>;
  const sectionTier0 = document.getElementById('section-tier0-specific');
  const sectionOrgContext = document.getElementById('section-org-context');
  const orgNameGroup = document.getElementById('org-name-group');

  function activateTier(value: string) {
    // Check radio
    const radio = document.querySelector(`.tier-radio[value="${value}"]`) as HTMLInputElement | null;
    if (radio) radio.checked = true;

    // Visual selection state
    tierOptions.forEach((opt) => {
      const selected = opt.dataset.tierValue === value;
      opt.style.borderColor = selected ? 'rgba(13,148,136,0.6)' : '';
      opt.style.backgroundColor = selected ? 'rgba(13,148,136,0.05)' : '';
    });

    // Show/hide conditional sections
    if (sectionTier0) sectionTier0.style.display = value === '0' ? 'block' : 'none';
    if (sectionOrgContext) sectionOrgContext.style.display = (value === '1' || value === '3') ? 'block' : 'none';
    if (orgNameGroup) orgNameGroup.style.display = (value === '1' || value === '3') ? 'block' : 'none';
  }

  // Radio/label click
  tierOptions.forEach((opt) => {
    opt.addEventListener('click', () => {
      if (opt.dataset.tierValue) activateTier(opt.dataset.tierValue);
    });
  });

  // Pre-select from URL query param  (e.g. ?tier=0#inquiry-form)
  const urlTier = new URLSearchParams(window.location.search).get('tier');
  if (urlTier && ['0', '1', '3'].includes(urlTier)) {
    activateTier(urlTier);
    setTimeout(() => {
      document.getElementById('inquiry-form')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 300);
  }

  // CTA buttons pre-select tier and scroll to form
  document.querySelectorAll('.cta-tier-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const tier = (btn as HTMLElement).dataset.tier;
      if (tier) {
        e.preventDefault();
        activateTier(tier);
        setTimeout(() => {
          document.getElementById('inquiry-form')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    });
  });

  // ── SCORING ────────────────────────────────────────────────────────────────
  type ScoreResult = {
    approved: boolean;
    score: number;
    reasons: string[];
    hardNoReasons: string[];
    decision: string;
  };

  function safe(v: unknown): string {
    return String(v || '').trim().toLowerCase();
  }

  function scoreTier0(data: Record<string, unknown>): ScoreResult {
    let score = 0;
    const reasons: string[] = [];
    const hardNoReasons: string[] = [];

    const inv = safe(data.investmentReadiness);
    const grp = safe(data.groupReadiness);
    const crisis = safe(data.crisisSupport);
    const vip = safe(data.vipInterest);
    const season = safe(data.currentSeason);
    const ai = safe(data.aiRole);
    const challenges = (Array.isArray(data.currentChallenges) ? data.currentChallenges : []).map(safe);
    const heavy = safe(data.heaviestRightNow);
    const auth = safe(data.authorityMismatch);
    const desired = safe(data.desiredValue);

    if (inv === 'not-at-this-time') hardNoReasons.push('Not prepared to invest at this time');
    if (grp === 'no-private-only') hardNoReasons.push('Not open to group format');
    if (crisis === 'yes') hardNoReasons.push('Seeking immediate crisis-level support');

    if (inv === 'yes-ready-now') { score += 30; reasons.push('Ready to invest'); }
    else if (inv === 'possibly-need-more-info') { score += 15; reasons.push('Possibly ready'); }

    if (grp === 'yes') { score += 20; reasons.push('Open to group format'); }
    else if (grp === 'maybe') { score += 8; reasons.push('Maybe open to group'); }

    if (vip.includes('vip')) { score += 10; reasons.push('VIP interest'); }
    else if (vip === 'group intensive only') { score += 6; reasons.push('Group interest'); }

    if (season) { score += 5; reasons.push('Season named'); }

    const fitWords = ['burnout', 'over-responsibility', 'hidden labor', 'leadership strain', 'transition', 'founder', 'ai overwhelm', 'authority', 'difficulty'];
    const hits = challenges.filter((c) => fitWords.some((w) => c.includes(w))).length;
    score += Math.min(hits * 4, 20);
    if (hits > 0) reasons.push(`Challenge fit: ${hits} signals`);

    if (auth.length > 30) { score += 12; reasons.push('Authority strain named'); }
    if (heavy.length > 30) { score += 8; reasons.push('Strain articulated'); }
    if (desired.length > 20) { score += 10; reasons.push('Desired outcome named'); }

    if (['pressure to do more faster', 'cleanup burden', 'mixed / all of the above', 'confusion / uncertainty'].includes(ai)) {
      score += 5; reasons.push('AI-era strain present');
    }

    const approved = hardNoReasons.length === 0 && score >= 55;
    return { approved, score, reasons, hardNoReasons, decision: approved ? 'approved-tier0-cohort' : 'not-approved-redirect' };
  }

  function scoreTier1(data: Record<string, unknown>): ScoreResult {
    let score = 0;
    const reasons: string[] = [];
    const hardNoReasons: string[] = [];

    const inv = safe(data.investmentReadiness);
    const crisis = safe(data.crisisSupport);
    const season = safe(data.currentSeason);
    const ref = safe(data.referralSource);
    const challenges = (Array.isArray(data.currentChallenges) ? data.currentChallenges : []).map(safe);
    const auth = safe(data.authorityMismatch);
    const desired = safe(data.desiredValue);
    const orgChallenge = safe(data.orgChallenge);

    if (inv === 'not-at-this-time') hardNoReasons.push('Not prepared to invest');
    if (crisis === 'yes') hardNoReasons.push('Seeking crisis-level support');

    if (inv === 'yes-ready-now') { score += 30; reasons.push('Ready to invest'); }
    else if (inv === 'possibly-need-more-info') { score += 20; reasons.push('Possibly ready'); }

    if (ref.includes('personally invited')) { score += 20; reasons.push('Direct invite from Nikki'); }
    else if (ref.includes('referred')) { score += 15; reasons.push('Trusted referral'); }
    else if (ref.includes('tier 0') || ref.includes('previous')) { score += 10; reasons.push('Prior engagement'); }

    if (season.includes('senior') || season.includes('executive') || season.includes('founder') || season.includes('nonprofit leader')) {
      score += 15; reasons.push('Leadership season');
    }

    const fitWords = ['leadership strain', 'over-responsibility', 'executive', 'organizational', 'founder'];
    const hits = challenges.filter((c) => fitWords.some((w) => c.includes(w))).length;
    score += Math.min(hits * 5, 20);
    if (hits > 0) reasons.push(`Leadership challenge fit: ${hits}`);

    if (auth.length > 40) { score += 10; reasons.push('Authority gap articulated'); }
    if (desired.length > 30) { score += 10; reasons.push('Desired outcome named'); }
    if (orgChallenge.length > 30) { score += 10; reasons.push('Org challenge named'); }

    const approved = hardNoReasons.length === 0 && score >= 60;
    return { approved, score, reasons, hardNoReasons, decision: approved ? 'approved-tier1-inquiry' : 'not-approved-redirect' };
  }

  function scoreTier3(data: Record<string, unknown>): ScoreResult {
    let score = 0;
    const reasons: string[] = [];
    const hardNoReasons: string[] = [];

    const inv = safe(data.investmentReadiness);
    const crisis = safe(data.crisisSupport);
    const sector = safe(data.orgSector);
    const headcount = safe(data.orgHeadcount);
    const ref = safe(data.referralSource);
    const orgChallenge = safe(data.orgChallenge);
    const auth = safe(data.authorityMismatch);
    const desired = safe(data.desiredValue);

    if (inv === 'not-at-this-time') hardNoReasons.push('Not prepared to invest');
    if (crisis === 'yes') hardNoReasons.push('Seeking crisis-level support');
    if (!sector || sector === 'independent / self-employed' || sector === '') {
      hardNoReasons.push('No organizational context — Tier 0 may be a better fit');
    }

    if (inv === 'yes-ready-now') { score += 30; reasons.push('Ready to invest'); }
    else if (inv === 'possibly-need-more-info') { score += 15; reasons.push('Possibly ready'); }

    if (ref.includes('personally invited')) { score += 20; reasons.push('Direct invite'); }
    else if (ref.includes('referred')) { score += 15; reasons.push('Trusted referral'); }

    if (sector && sector !== '' && sector !== 'independent / self-employed') {
      score += 20; reasons.push(`Org sector: ${sector}`);
    }

    if (headcount.includes('small') || headcount.includes('mid') || headcount.includes('large')) {
      score += 10; reasons.push('Org size identified');
    }

    if (orgChallenge.length > 40) { score += 15; reasons.push('Strategic org challenge named'); }
    if (auth.length > 40) { score += 10; reasons.push('Authority gap articulated'); }
    if (desired.length > 30) { score += 10; reasons.push('Desired outcome named'); }

    const approved = hardNoReasons.length === 0 && score >= 65;
    return { approved, score, reasons, hardNoReasons, decision: approved ? 'approved-tier3-advisory' : 'not-approved-redirect' };
  }

  // ── FORM SUBMISSION ────────────────────────────────────────────────────────
  const form = document.getElementById('fractional-form') as HTMLFormElement | null;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const labelEl = document.getElementById('submit-label');
  const spinner = document.getElementById('submit-spinner');
  const statusEl = document.getElementById('form-status');

  function showStatus(html: string, className: string) {
    if (!form || !statusEl) return;
    form.classList.add('hidden');
    statusEl.classList.remove('hidden');
    statusEl.className = className;
    statusEl.innerHTML = html;
    statusEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const selectedTierRadio = document.querySelector('.tier-radio:checked') as HTMLInputElement | null;
    if (!selectedTierRadio) {
      alert('Please select which offering you are inquiring about at the top of the form.');
      return;
    }

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    if (btn && labelEl && spinner) {
      btn.disabled = true;
      labelEl.textContent = 'Reviewing...';
      spinner.classList.remove('hidden');
    }

    const fd = new FormData(form);
    const selectedTier = selectedTierRadio.value;

    const data: Record<string, unknown> = {
      selectedTier,
      fullName: fd.get('fullName')?.toString() || '',
      email: fd.get('email')?.toString() || '',
      orgName: fd.get('orgName')?.toString() || '',
      currentSeason: fd.get('currentSeason')?.toString() || '',
      currentChallenges: fd.getAll('currentChallenges').map(String),
      heaviestRightNow: fd.get('heaviestRightNow')?.toString() || '',
      authorityMismatch: fd.get('authorityMismatch')?.toString() || '',
      aiRole: fd.get('aiRole')?.toString() || '',
      desiredValue: fd.get('desiredValue')?.toString() || '',
      investmentReadiness: fd.get('investmentReadiness')?.toString() || '',
      crisisSupport: fd.get('crisisSupport')?.toString() || '',
      groupReadiness: fd.get('groupReadiness')?.toString() || '',
      vipInterest: fd.get('vipInterest')?.toString() || '',
      cohortPreference: fd.get('cohortPreference')?.toString() || '',
      orgSector: fd.get('orgSector')?.toString() || '',
      orgHeadcount: fd.get('orgHeadcount')?.toString() || '',
      orgChallenge: fd.get('orgChallenge')?.toString() || '',
      referralSource: fd.get('referralSource')?.toString() || '',
      anythingElse: fd.get('anythingElse')?.toString() || '',
    };

    let review: ScoreResult;
    if (selectedTier === '0') review = scoreTier0(data);
    else if (selectedTier === '1') review = scoreTier1(data);
    else review = scoreTier3(data);

    // ── NOT APPROVED ──
    if (!review.approved) {
      const hasNoOrgContext = review.hardNoReasons.some((r) => r.toLowerCase().includes('no organizational'));
      if ((selectedTier === '1' || selectedTier === '3') && hasNoOrgContext) {
        showStatus(
          `<p class="font-heading text-xl text-light font-semibold mb-3">Tier ${selectedTier} may not be the right fit right now.</p>
          <p class="text-muted text-sm max-w-2xl mx-auto mb-4">
            Tier 1 and Tier 3 engagements are designed for organizational and leadership contexts with defined teams or structures. If you are navigating individual burnout or transition, the Strategic Reset Intensive (Tier 0) may be a stronger starting place.
          </p>
          <div class="flex flex-wrap justify-center gap-4 mt-6">
            <a href="?tier=0#inquiry-form" class="btn-teal">Apply for Tier 0 Instead</a>
            <a href="https://nikkicates.github.io/book" class="btn-outline-teal">Explore the Books</a>
          </div>`,
          'text-center p-6 rounded-md border border-border bg-surface/60'
        );
      } else {
        showStatus(
          `<p class="font-heading text-xl text-light font-semibold mb-3">This may not be the right container right now.</p>
          <p class="text-muted text-sm max-w-2xl mx-auto mb-4">
            Based on your responses, this engagement may not be the best next step for this season. That does not diminish what you are carrying — it means a different entry point may serve you better.
          </p>
          <p class="text-muted text-sm max-w-2xl mx-auto mb-6">
            A strong place to begin is the UNMASK Blueprint and the Unbothered Collective newsletter.
          </p>
          <div class="flex flex-wrap justify-center gap-4 mt-6">
            <a href="https://nikkicates.github.io/book" class="btn-teal">Explore the Books</a>
            <a href="https://api.leadconnectorhq.com/widget/form/n1afrRyJLvJOME1jHLGo" class="btn-outline-teal">Join the Newsletter</a>
          </div>`,
          'text-center p-6 rounded-md border border-border bg-surface/60'
        );
      }
      return;
    }

    // ── APPROVED — send to GHL ──
    const tierLabels: Record<string, string> = {
      '0': 'strategic-reset-intensive',
      '1': 'premium-intensive',
      '3': 'fractional-strategic-advisory',
    };

    const payload = new URLSearchParams({
      name: String(data.fullName),
      email: String(data.email),
      orgName: String(data.orgName),
      currentSeason: String(data.currentSeason),
      currentChallenges: (data.currentChallenges as string[]).join(', '),
      heaviestRightNow: String(data.heaviestRightNow),
      authorityMismatch: String(data.authorityMismatch),
      aiRole: String(data.aiRole),
      desiredValue: String(data.desiredValue),
      groupReadiness: String(data.groupReadiness),
      vipInterest: String(data.vipInterest),
      cohortPreference: String(data.cohortPreference),
      orgSector: String(data.orgSector),
      orgHeadcount: String(data.orgHeadcount),
      orgChallenge: String(data.orgChallenge),
      referralSource: String(data.referralSource),
      investmentReadiness: String(data.investmentReadiness),
      crisisSupport: String(data.crisisSupport),
      anythingElse: String(data.anythingElse),
      selectedTier,
      qualificationScore: String(review.score),
      qualificationDecision: review.decision,
      qualificationReasons: review.reasons.join(' | '),
      hardNoReasons: review.hardNoReasons.join(' | '),
      formType: `fractional-lane-${tierLabels[selectedTier] || 'inquiry'}`,
      source: 'nikkicates.github.io',
      tags: `fractional-lane, tier-${selectedTier}-inquiry, ${tierLabels[selectedTier] || 'inquiry'}, qualified-inquiry`,
    });

    try {
      await fetch(
        'https://services.leadconnectorhq.com/hooks/35XiTsvy0Kt7TRNBabas/webhook-trigger/a7d18c81-570c-4e47-844a-94797c3e3b17',
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
          body: payload.toString(),
          mode: 'no-cors',
        }
      );

      const successMessages: Record<string, { heading: string; body: string }> = {
        '0': {
          heading: "You've been added to the cohort interest list.",
          body: "Thank you for your inquiry. Based on your responses, this looks like a strong fit for the Strategic Reset Intensive. You'll be contacted with next-step details for the upcoming cohort — and VIP information if requested.",
        },
        '1': {
          heading: 'Your Premium Intensive inquiry has been received.',
          body: "Thank you for reaching out. Your inquiry is being reviewed and you'll be contacted with next steps if this engagement is the right fit for this season. Details are shared only after fit is confirmed.",
        },
        '3': {
          heading: 'Your advisory inquiry has been received.',
          body: "Thank you for your inquiry. Tier 3 engagements are highly selective. Your submission will be reviewed and you'll hear back if this is the right next step. We take our capacity limits seriously.",
        },
      };

      const msg = successMessages[selectedTier] || successMessages['0'];
      showStatus(
        `<p class="font-heading text-xl text-teal-DEFAULT font-semibold mb-2">${msg.heading}</p>
        <p class="text-muted text-sm max-w-2xl mx-auto mb-4">${msg.body}</p>
        <p class="text-muted text-sm max-w-2xl mx-auto mb-6">
          In the meantime, take a breath. The fact that something feels unsustainable does not mean you are failing. It may mean you have been carrying what was never meant to rest on you alone.
        </p>
        <div class="flex flex-wrap justify-center gap-4 mt-6">
          <a href="https://nikkicates.github.io/book" class="btn-outline-teal">Explore the Books</a>
        </div>`,
        'text-center p-6 rounded-md border border-teal-DEFAULT/40 bg-teal-glow'
      );
    } catch {
      if (btn && labelEl && spinner) {
        btn.disabled = false;
        labelEl.textContent = 'Submit Inquiry';
        spinner.classList.add('hidden');
      }
      if (statusEl) {
        statusEl.classList.remove('hidden');
        statusEl.className = 'text-center p-6 rounded-md border border-red-500/40 bg-red-900/10';
        statusEl.innerHTML = `<p class="text-red-400 text-sm">Something went wrong. Please email <a href="mailto:info@nikkicates.com" class="underline">info@nikkicates.com</a> directly.</p>`;
        statusEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  });
</script>
