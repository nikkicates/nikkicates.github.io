---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="bg-zinc-950 text-zinc-100 min-h-screen flex flex-col items-center justify-center px-6 py-12">
    <div class="max-w-md w-full text-center">
      <h1 class="text-5xl font-bold tracking-tighter mb-2">Nikki Cates</h1>
      <p class="text-teal-400 text-sm font-bold uppercase tracking-widest">Structural Recalibration Strategist</p>
      
      <div class="mt-12 space-y-4">
        <a href="/structural-burnout/briefing" class="block w-full bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 hover:border-teal-400 rounded-3xl py-6 px-8 text-left transition">
          <span class="block text-teal-400 text-xs font-bold uppercase">Start Here</span>
          <span class="text-lg font-semibold">Structural Leadership Diagnostic</span>
        </a>

        <a href="/structural-burnout/services" class="block w-full bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 hover:border-teal-400 rounded-3xl py-6 px-8 text-left transition">
          <span class="block text-teal-400 text-xs font-bold uppercase">Speaking & Formation</span>
          <span class="text-lg font-semibold">Book an Engagement</span>
        </a>

        <a href="https://calendar.google.com/appointments/schedules/AcZssZ0wzeoxprLGxanzVAEMZB_aBMMuQycSnCwYHy3gsd1R3wpmUCMIHmegk-UbZzU2nRZb_XiI_I3o" 
           target="_blank"
           class="block w-full bg-teal-400 hover:bg-teal-300 text-zinc-950 font-semibold rounded-3xl py-6">
          Schedule Executive Briefing
        </a>
      </div>

      <div class="mt-16 text-xs text-zinc-500">
        Strategic Transformations © 2026
      </div>
    </div>
  </div>
</Layout>