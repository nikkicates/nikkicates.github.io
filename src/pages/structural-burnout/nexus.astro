---
import Layout from '../../layouts/Layout.astro';

const hasPhoto = true;
const photoSrc = '/images/nikki-cates.png';
---

<Layout
  title="Nexus Card — Nikki Cates"
  description="Digital networking card for Nikki Cates — Structural Recalibration Strategist, Author, Army Veteran, and Founder of Strategic Transformations."
  section="st"
  accentColor="teal"
>

  <section class="min-h-screen flex items-center justify-center py-12 px-4 relative overflow-hidden">
    <div class="absolute inset-0 bg-[#0f172a]"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 60% at 50% 40%, rgba(13,148,136,0.1) 0%, transparent 60%);"></div>

    <div class="relative z-10 w-full max-w-md">

      <!-- Top gradient bar -->
      <div class="h-[3px] w-full mb-6 rounded-full" style="background: linear-gradient(to right, transparent, #0d9488, #0f4c7a, transparent);"></div>

      <!-- DOWNLOAD CONTACT CARD — prominent at top -->
      <a
        href="/nikki-cates.vcf"
        class="w-full flex items-center justify-center gap-3 mb-6 py-3.5 px-5 rounded-md border border-teal-DEFAULT/50 font-body font-bold text-sm text-teal-DEFAULT transition-all no-underline"
        style="background: rgba(13,148,136,0.12);"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Save Contact to Phone
      </a>

      <!-- Identity -->
      <div class="text-center mb-7">

        <!-- Photo -->
        <div class="w-36 h-36 rounded-full mx-auto mb-4 overflow-hidden border-2 border-teal-DEFAULT/50 relative"
             style="background: linear-gradient(135deg, #0f4c7a, #0d9488);">
          {hasPhoto ? (
            <img
              src={photoSrc}
              alt="Nikki Cates"
              width="144"
              height="144"
              class="w-full h-full object-cover object-center"
              loading="eager"
              fetchpriority="high"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center">
              <span class="font-heading text-white text-2xl font-bold select-none">NC</span>
            </div>
          )}
        </div>

        <h1 class="font-heading text-2xl text-light font-bold mb-1">Nikki Cates</h1>
        <p class="font-body text-teal-DEFAULT text-xs font-bold uppercase tracking-widest mb-2">
          Fractional Structural Advisor | Leadership Architecture
        </p>
        <p class="text-muted text-xs leading-relaxed max-w-xs mx-auto">
          Founder, Strategic Transformations &amp; URI ·
          Army Veteran · Author · AI-Era Organizational Strategist
        </p>
        <p class="text-light text-sm font-semibold leading-relaxed max-w-xs mx-auto mt-4">
          Burnout is the smoke alarm. Your Leadership Architecture is the fire.
        </p>
      </div>

      <!-- Divider -->
      <div class="h-px bg-border mb-5"></div>

      <!-- About (third-person) -->
      <div class="bg-surface/60 border border-border rounded-md p-4 mb-5">
        <p class="text-muted text-sm leading-relaxed">
          Nikki Cates helps executives, boards, and organizations identify and dismantle the
          structural conditions producing burnout, attrition, and systemic exhaustion.
          She is the creator of the <span class="text-teal-DEFAULT font-semibold">UNMASK Framework</span>
          and author of the three-volume UNMASK Blueprint Series.
        </p>
      </div>

      <!-- Entry links -->
      <div class="space-y-2.5 mb-7">
        <p class="font-body text-xs font-bold uppercase tracking-widest text-muted text-center mb-3">
          Leadership Architecture Pathways
        </p>

        {[
          {
            label: '2026 Leadership Architecture Whitepaper',
            sub: 'Download the UNMASK Diagnostic Suite whitepaper',
            href: 'https://drive.google.com/file/d/18mGg0ML4pnviaw3KZ90M00rgfNxr3LvM/view?usp=sharing',
            icon: 'file-text',
            primary: true,
            external: true,
          },
          {
            label: 'Calculate Structural Strain Score',
            sub: 'Take the baseline diagnostic now',
            href: 'https://form.typeform.com/to/eo5W8Zio',
            icon: 'activity',
            external: true,
          },
          {
            label: 'Request Executive Briefing',
            sub: 'For leadership architecture risk and recalibration decisions',
            href: 'https://nikkicates.github.io/structural-burnout/briefing/',
            icon: '📋',
          },
          {
            label: 'Fractional Advisory & Recalibration',
            sub: 'Embedded partnership and 90-day structural work',
            href: 'https://nikkicates.github.io/structural-burnout/fractional-lane/',
            icon: '🏗️',
          },
        ].map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener' : undefined}
            class={`flex items-center gap-4 p-3.5 rounded-md border transition-all no-underline group
              ${link.primary
                ? 'bg-teal-DEFAULT/10 border-teal-DEFAULT/50 hover:bg-teal-DEFAULT/20'
                : 'bg-surface/40 border-border hover:border-teal-DEFAULT/30'
              }`}
          >
            <span class="text-xl shrink-0">
              {link.icon === 'file-text' ? (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                  <line x1="16" y1="13" x2="8" y2="13" />
                  <line x1="16" y1="17" x2="8" y2="17" />
                  <line x1="10" y1="9" x2="8" y2="9" />
                </svg>
              ) : link.icon === 'activity' ? (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                </svg>
              ) : (
                link.icon
              )}
            </span>
            <div class="flex-1 min-w-0">
              <p class={`font-body font-semibold text-sm ${link.primary ? 'text-teal-DEFAULT' : 'text-light'}`}>
                {link.label}
              </p>
              <p class="text-muted text-xs truncate">{link.sub}</p>
            </div>
            <svg class="w-4 h-4 text-muted/50 shrink-0 group-hover:text-teal-DEFAULT group-hover:translate-x-0.5 transition-all" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- Strategic discovery -->
      <div class="bg-surface/60 border border-border rounded-md p-4 mb-5">
        <p class="font-body text-xs font-bold uppercase tracking-widest text-teal-DEFAULT mb-3">
          Strategic Discovery
        </p>
        <ul class="space-y-2 text-sm text-muted">
          <li>Where are your highest-capacity people carrying the most pressure right now?</li>
          <li>Do they have the authority to match their responsibility?</li>
          <li>What is the cost in execution drag and talent loss?</li>
        </ul>
      </div>

      <!-- Secondary links -->
      <div class="space-y-2.5 mb-7">
        <p class="font-body text-[10px] font-bold uppercase tracking-widest text-muted/80 text-center mb-2">
          Additional Links
        </p>
        {[
          {
            label: 'URI Formation',
            sub: 'Leadership formation resources',
            href: '/uri/',
            icon: '✊🏾',
          },
          {
            label: 'UNMASK Books',
            sub: 'Volumes, bundles, and institutional options',
            href: '/books/',
            icon: '📖',
          },
          {
            label: 'LinkedIn',
            sub: 'linkedin.com/in/nikkicatesmiller',
            href: 'https://www.linkedin.com/in/nikkicatesmiller',
            icon: '🔗',
            external: true,
          },
        ].map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener' : undefined}
            class="flex items-center gap-4 p-3 rounded-md border border-border/70 bg-surface/20 hover:border-teal-DEFAULT/30 transition-all no-underline group"
          >
            <span class="text-lg shrink-0 opacity-80">{link.icon}</span>
            <div class="flex-1 min-w-0">
              <p class="font-body font-semibold text-sm text-light/90">{link.label}</p>
              <p class="text-muted text-xs truncate">{link.sub}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Contact links -->
      <div class="space-y-2.5 mb-7">
        {[
          {
            label: 'Call or Text',
            sub: '1-407-693-4449',
            href: 'tel:+14076934449',
            icon: '📞',
          },
          {
            label: 'Email Directly',
            sub: 'nikki@strategicunmasking.com',
            href: 'mailto:nikki@strategicunmasking.com',
            icon: '✉️',
          },
        ].map((link) => (
          <a
            href={link.href}
            class="flex items-center gap-4 p-3.5 rounded-md border border-border bg-surface/40 hover:border-teal-DEFAULT/30 transition-all no-underline group"
          >
            <span class="text-xl shrink-0">{link.icon}</span>
            <div class="flex-1 min-w-0">
              <p class="font-body font-semibold text-sm text-light">{link.label}</p>
              <p class="text-muted text-xs truncate">{link.sub}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Second download nudge at bottom -->
      <a
        href="/nikki-cates.vcf"
        class="w-full flex items-center justify-center gap-2 mb-5 py-2.5 px-4 rounded-md text-xs font-body font-bold uppercase tracking-widest text-muted border border-border hover:border-teal-DEFAULT/40 hover:text-teal-DEFAULT transition-all no-underline"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Save Contact Card (.vcf)
      </a>

      <!-- Footer -->
      <div class="text-center">
        <p class="text-muted text-xs italic mb-1">
          "Burnout is a design flaw. We fix the design."
        </p>
        <p class="text-muted/50 text-xs">
          © {new Date().getFullYear()} Nikki Cates · Strategic Transformations
        </p>
      </div>

      <!-- Bottom gradient bar -->
      <div class="h-[3px] w-full mt-6 rounded-full" style="background: linear-gradient(to right, transparent, #0f4c7a, #0d9488, transparent);"></div>

    </div>
  </section>

</Layout>
