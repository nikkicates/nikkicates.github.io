---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="bg-zinc-950 text-zinc-100 min-h-screen">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <!-- Back link + Header -->
      <a href="/structural-burnout" class="inline-flex items-center gap-2 text-teal-400 hover:text-teal-300 mb-8 text-sm">
        ← Back to Structural Burnout
      </a>

      <h1 class="text-5xl md:text-6xl font-bold tracking-tighter mb-6">
        Solutions &amp; Services
      </h1>
      <p class="text-xl text-zinc-400 max-w-3xl">
        High-authority diagnostics and tactical recalibration tools. From signature keynotes that shift the room to full enterprise architectural redesign.
      </p>

      <!-- Speaker & Formation Section -->
      <section class="mt-20">
        <div class="flex items-center gap-3 mb-8">
          <span class="px-4 py-1 bg-teal-400/10 text-teal-400 text-xs font-bold uppercase tracking-widest rounded-full">Signature Talks</span>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- Talk 1 -->
          <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 hover:border-teal-400/50 transition">
            <span class="inline-block px-3 py-1 bg-zinc-800 text-teal-400 text-[10px] font-bold uppercase tracking-widest rounded-full mb-4">Anchor Keynote</span>
            <h3 class="text-2xl font-bold mb-4">Stop the Strain Transfer: Why Your Best Leaders Are Burning Out</h3>
            <p class="text-zinc-400">Burnout is not a resilience problem — it is a structural one. This talk dismantles the myth that wellness programs can fix an engineering failure.</p>
            <p class="text-xs text-zinc-500 mt-6">Best for: Conferences · ERG Leadership Days · HR &amp; People Ops Summits</p>
          </div>

          <!-- Talk 2 -->
          <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 hover:border-teal-400/50 transition">
            <span class="inline-block px-3 py-1 bg-zinc-800 text-teal-400 text-[10px] font-bold uppercase tracking-widest rounded-full mb-4">Women's Leadership</span>
            <h3 class="text-2xl font-bold mb-4">Sovereign Power: Leading Without Running on Empty</h3>
            <p class="text-zinc-400">For high-performing leaders who have mastered the role and are quietly depleted by it.</p>
            <p class="text-xs text-zinc-500 mt-6">Best for: Women's Leadership Events · ERGs · Founder Gatherings</p>
          </div>
        </div>
      </section>

      <!-- URI Formation Track -->
      <section class="mt-24 pt-16 border-t border-zinc-800">
        <div class="flex items-center gap-3 mb-8">
          <span class="px-4 py-1 bg-purple-500/10 text-purple-400 text-xs font-bold uppercase tracking-widest rounded-full">URI Formation</span>
        </div>
        <h2 class="text-4xl font-bold tracking-tighter mb-6">Sovereign Leadership for the Whole Person</h2>
        <p class="text-zinc-400 max-w-2xl">
          Carried out under the values infrastructure of Unbothered Resistance International (URI). Designed for faith-based, justice-centered, and academic communities.
        </p>

        <div class="mt-12 grid md:grid-cols-2 gap-8">
          <div class="bg-zinc-900/70 border border-purple-500/30 rounded-3xl p-8">
            <h3 class="text-xl font-bold mb-4">Unbothered: Reclaiming Authority in Systems That Were Never Built for You</h3>
            <p class="text-zinc-400">For leaders carrying the weight of institutional survival alongside the cost of authentic leadership.</p>
          </div>
          <div class="bg-zinc-900/70 border border-purple-500/30 rounded-3xl p-8">
            <h3 class="text-xl font-bold mb-4">From Compliance to Architecture: Making DEIA Work That Actually Works</h3>
            <p class="text-zinc-400">For organizations that have invested in DEIA and aren't seeing structural change.</p>
          </div>
        </div>
      </section>

      <!-- Engagement Journey / Tiers -->
      <section class="mt-24">
        <h2 class="text-4xl font-bold tracking-tighter mb-12 text-center">The Recalibration Journey</h2>
        
        <div class="grid md:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="text-teal-400 text-5xl mb-4">01</div>
            <h4 class="font-bold mb-2">Keynote / Workshop</h4>
            <p class="text-xs text-zinc-500">Starting at $12,500</p>
          </div>
          <div class="text-center">
            <div class="text-teal-400 text-5xl mb-4">02</div>
            <h4 class="font-bold mb-2">UNMASK Diagnostic</h4>
            <p class="text-xs text-zinc-500">Starting at $22,000</p>
          </div>
          <div class="text-center">
            <div class="text-teal-400 text-5xl mb-4">03</div>
            <h4 class="font-bold mb-2">UNMASK Recalibration</h4>
            <p class="text-xs text-zinc-500">Starting at $45,000</p>
          </div>
          <div class="text-center">
            <div class="text-teal-400 text-5xl mb-4">04</div>
            <h4 class="font-bold mb-2">Stabilization Retainer</h4>
            <p class="text-xs text-zinc-500">Starting at $7,500/mo</p>
          </div>
        </div>
      </section>

      <!-- Final CTA -->
      <div class="mt-24 bg-zinc-900 border border-zinc-700 rounded-3xl p-12 text-center">
        <h3 class="text-3xl font-bold mb-4">Ready to fix the structure?</h3>
        <p class="text-zinc-400 mb-8">Let's schedule a briefing and locate exactly where the authority gaps are breaking your leadership core.</p>
        <a href="https://calendar.google.com/appointments/schedules/AcZssZ0wzeoxprLGxanzVAEMZB_aBMMuQycSnCwYHy3gsd1R3wpmUCMIHmegk-UbZzU2nRZb_XiI_I3o" 
           target="_blank"
           class="inline-block px-10 py-5 bg-[#064680] hover:bg-[#2a7ca3] text-white font-semibold rounded-2xl transition">
          Schedule Briefing
        </a>
      </div>
    </div>
  </div>
</Layout>