---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="bg-zinc-950 text-zinc-100 min-h-screen">
    <!-- Back link -->
    <div class="pt-8 px-6 max-w-5xl mx-auto">
      <a href="/structural-burnout" class="inline-flex items-center gap-2 text-teal-400 hover:text-teal-300 text-sm">
        ← Back to Structural Burnout
      </a>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16">
      <h1 class="text-5xl md:text-6xl font-bold tracking-tighter mb-4">
        Solutions &amp; Engagements
      </h1>
      <p class="text-xl text-zinc-400 mb-16">
        From keynotes to full enterprise recalibration — choose the right level of intervention.
      </p>

      <!-- Speaking Engagements -->
      <div class="mb-20">
        <h2 class="text-3xl font-semibold mb-8 text-teal-400">Speaking &amp; Keynotes</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-3xl">
            <h3 class="text-2xl font-semibold mb-4">"Stop the Strain Transfer"</h3>
            <p class="text-zinc-400">How leadership architecture leaks capacity and how to plug it.</p>
          </div>
          <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-3xl">
            <h3 class="text-2xl font-semibold mb-4">"The Authority Gap in the Age of AI"</h3>
            <p class="text-zinc-400">Why AI multiplies cracked structures 10× and what to do about it.</p>
          </div>
        </div>
        <p class="text-sm text-zinc-500 mt-6">*More engagements available — we'll expand this list in the fine-tune round as you requested.</p>
      </div>

      <!-- URI Formation Track -->
      <div class="mb-20">
        <h2 class="text-3xl font-semibold mb-8 text-purple-400">Unbothered Resistance International (URI) Formation</h2>
        <div class="bg-zinc-900 border border-purple-400/30 p-10 rounded-3xl">
          <p class="text-zinc-400 leading-relaxed">
            Multi-tier leadership formation grounded in faith, justice, and capacity protection. 
            Deep work for leaders ready to recalibrate at the structural level.
          </p>
        </div>
      </div>

      <!-- UNMASK Leadership Architecture Journey -->
      <div class="mb-20">
        <h2 class="text-3xl font-semibold mb-8">UNMASK Leadership Architecture Journey</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-3xl">
            <div class="text-teal-400 text-sm font-bold uppercase tracking-widest mb-3">Tier 1–2</div>
            <h3 class="text-2xl font-semibold mb-4">Diagnostic &amp; Foundation</h3>
            <p class="text-zinc-400">Structural Audit + initial recalibration sessions.</p>
            <p class="text-teal-400 font-semibold mt-6">Starting at $X,XXX</p>
          </div>
          <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-3xl">
            <div class="text-teal-400 text-sm font-bold uppercase tracking-widest mb-3">Tier 3–4</div>
            <h3 class="text-2xl font-semibold mb-4">Full Architectural Redesign</h3>
            <p class="text-zinc-400">Enterprise-level implementation and ongoing capacity protection.</p>
            <p class="text-teal-400 font-semibold mt-6">Starting at $XX,XXX</p>
          </div>
        </div>
        <p class="text-xs text-zinc-500 mt-8">*Pricing shown as "starting at" only — full tiers and details to be refined later as requested.</p>
      </div>

      <!-- CTA -->
      <div class="text-center py-16 border-t border-zinc-800">
        <h3 class="text-3xl font-semibold mb-6">Ready to Protect Capacity?</h3>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://calendar.google.com/appointments/schedules/AcZssZ0wzeoxprLGxanzVAEMZB_aBMMuQycSnCwYHy3gsd1R3wpmUCMIHmegk-UbZzU2nRZb_XiI_I3o" 
             target="_blank"
             class="px-10 py-6 bg-teal-400 hover:bg-teal-300 text-zinc-950 font-semibold rounded-3xl">
            Book Executive Briefing
          </a>
          <a href="/structural-burnout/briefing" 
             class="px-10 py-6 border border-zinc-700 hover:border-teal-400 font-semibold rounded-3xl">
            Start the Diagnostic
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>