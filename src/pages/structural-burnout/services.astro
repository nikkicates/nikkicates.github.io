---
import Layout from '../../layouts/Layout.astro';

const tiers = [
  {
    tag: 'Speaking',
    name: 'AI-Era Leadership Keynote',
    price: 'Proposal-based',
    duration: '60–90 min',
    desc: 'Executive-facing speaking for organizations navigating AI acceleration, hidden labor, burnout, decision friction, and human sustainability. Built around Nikki Cates\' revised Human x AI workforce platform.',
    includes: [
      'Pre-event discovery call',
      'Custom talk arc aligned to event theme and audience',
      'Primary topics include AI Accelerates What Exists and The Frictionless Manager',
      'Post-keynote digital resource or reflection guide for attendees',
      'Travel & hospitality requirements apply (see below)',
    ],
    cta: 'Request Executive Briefing',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'Workshop',
    name: 'Frictionless Manager Training',
    price: 'Proposal-based',
    duration: 'Half-Day / Full-Day / Series',
    desc: 'Manager enablement for the Human x AI workplace. This practical training uses UNMASK Leadership Architecture to reduce structural drag, improve communication, pace AI implementation, and realign responsibility with authority.',
    includes: [
      'Manager-facing training on structural strain and implementation friction',
      'DISC-informed communication and behavioral difference mapping',
      'Emotional intelligence and spiritual intelligence integration',
      'AI adoption pacing, advocacy upward, and responsibility-authority alignment',
      'Post-workshop integration notes',
    ],
    cta: 'Request Executive Briefing',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'Diagnostic',
    name: 'UNMASK Diagnostic Architecture',
    price: 'Proposal-based',
    duration: '4–6 Weeks',
    desc: 'A deep organizational diagnostic using the UNMASK Framework. Surfaces structural burnout, hidden labor, leadership masking, authority gaps, and the human strain AI acceleration may intensify.',
    includes: [
      'Organizational intake and structural mapping',
      'UNMASK pillar assessment across 3–5 key teams',
      'Leadership interview protocol',
      'Responsibility-authority alignment review',
      'Full Diagnostic Report with Findings & Recommendations',
      'Executive Debrief session',
      '90-day monitoring check-in',
    ],
    cta: 'Request Diagnostic Briefing',
    href: '/structural-burnout/briefing',
    featured: true,
  },
  {
    tag: 'Strategic Reset',
    name: 'Strategic Reset Intensive',
    price: 'Proposal-based',
    duration: 'Half-Day / Full-Day / 2-Day',
    desc: 'A focused leadership recalibration experience for teams preparing for AI implementation, restructuring, growth, or cultural repair. Designed to create shared language, decision clarity, and a prioritized reset agenda.',
    includes: [
      'Pre-intensive leadership intake',
      'Structural burnout and hidden labor mapping',
      'Decision friction and responsibility-authority review',
      'Leadership recalibration session using UNMASK Architecture',
      'Reset priorities and 30-day implementation rhythm',
    ],
    cta: 'Request Strategic Reset',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'Recalibration',
    name: 'UNMASK Recalibration Engagement',
    price: 'Contact for Scope',
    duration: '90 Days',
    desc: 'The full recalibration experience. Moves from diagnosis through structural redesign and implementation support so organizations can reduce drag, protect human capacity, and lead AI-era change with clearer architecture.',
    includes: [
      'Full Diagnostic Architecture',
      'Structural redesign sessions with leadership team',
      'Department-level recalibration workshops',
      'Implementation roadmap with accountability checkpoints',
      'Monthly cohort debriefs (3)',
      'Custom UNMASK organizational playbook',
      '6-month post-engagement check-in',
    ],
    cta: 'Request Recalibration Briefing',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'Advisory',
    name: 'Leadership Recalibration Retainer',
    price: 'Contact for Scope',
    duration: 'Ongoing (3-month minimum)',
    desc: 'For organizations that need ongoing strategic counsel as leaders implement AI-era operating changes, manager enablement, structural repair, and human sustainability priorities.',
    includes: [
      '2 strategic advisory sessions per month',
      'Async communication channel access',
      'Monthly structural health review',
      'Course-correction support',
      'Priority access for urgent escalations',
    ],
    cta: 'Apply for Retainer',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'AI Readiness',
    name: 'Human x AI Workforce Readiness Audit',
    price: 'Proposal-based',
    duration: '4–6 Weeks',
    desc: 'A specialized diagnostic for organizations deploying AI tools at scale. Identifies how automation may accelerate existing burnout patterns, hidden labor, decision bottlenecks, authority gaps, and cultural debt.',
    includes: [
      'AI deployment impact assessment',
      'Human x AI workforce readiness mapping',
      'Leadership readiness review for AI-era shifts',
      'Structural strain and hidden labor risk scan',
      'Full Audit Report with Risk Matrix',
      'Strategic mitigation recommendations',
    ],
    cta: 'Request Readiness Briefing',
    href: '/structural-burnout/briefing',
  },
];

const categories = [
  'AI-era leadership strategy',
  'Human x AI workforce readiness',
  'Frictionless Manager training',
  'Organizational diagnostics',
  'Structural burnout and hidden labor',
  'Responsibility-authority alignment',
  'UNMASK Leadership Architecture',
  'Strategic Reset Intensives and leadership recalibration',
];
---

<Layout
  title="Services - Strategic Transformations"
  description="Speaking, workshops, organizational diagnostics, and leadership recalibration for AI-era organizations preparing for the Human x AI workforce alliance."
  section="st"
  accentColor="teal"
>

  <!-- ─── HERO ─────────────────────────────────────── -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-st-gradient"></div>
    <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-teal-DEFAULT"></div>
    <div class="container-mid relative z-10 text-center">
      <h1 class="font-heading text-4xl md:text-6xl text-light font-bold mb-5 animate-on-scroll">
        Recalibrate the structure<br/>AI acceleration exposes.
      </h1>
      <p class="text-muted text-lg max-w-2xl mx-auto mb-8 animate-on-scroll" style="animation-delay:0.1s">
        Strategic Transformations helps organizations diagnose and recalibrate the human and structural
        strain AI acceleration reveals: burnout, hidden labor, decision friction, leadership masking,
        authority gaps, and cultural debt.
      </p>
      <a href="/structural-burnout/briefing" class="btn-teal animate-on-scroll" style="animation-delay:0.2s">
        Request Executive Briefing →
      </a>
    </div>
  </section>


  <!-- ─── POSITIONING CATEGORIES ───────────────────── -->
  <section class="py-14 bg-[#0c1525] border-y border-border">
    <div class="container-wide">
      <div class="text-center mb-8 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Strategic Transformation Categories</span>
        <h2 class="font-heading text-2xl md:text-3xl text-light mb-4">
          Built for leaders preparing the Human x AI workforce alliance.
        </h2>
        <p class="text-muted max-w-3xl mx-auto">
          Nikki Cates works at the intersection of AI-era leadership, structural burnout,
          organizational diagnostics, behavioral science, emotional intelligence, spiritual intelligence,
          and human sustainability.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {categories.map((category) => (
          <div class="card teal-hover py-4 px-5 animate-on-scroll">
            <p class="text-light text-sm font-semibold">{category}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── TIERS ─────────────────────────────────────── -->
  <section class="section-pad">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {tiers.map((tier) => (
          <div class={`card teal-hover flex flex-col gap-4 relative animate-on-scroll ${tier.featured ? 'border-teal-DEFAULT/60 bg-teal-glow' : ''}`}>
            {tier.featured && (
              <div class="absolute -top-3 left-5">
                <span class="bg-teal-DEFAULT text-[#0f172a] text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-sm font-body">
                  Most Requested
                </span>
              </div>
            )}
            <div class="flex items-start justify-between gap-4">
              <div>
                <span class="st-tag text-xs mb-2 inline-flex">{tier.tag}</span>
                <h2 class="font-heading text-xl text-light font-bold">{tier.name}</h2>
              </div>
              <div class="text-right shrink-0">
                <p class="font-body text-teal-DEFAULT font-bold text-sm">{tier.price}</p>
                <p class="text-muted text-xs mt-1">{tier.duration}</p>
              </div>
            </div>
            <p class="text-muted text-sm leading-relaxed">{tier.desc}</p>
            <ul class="space-y-2 flex-1">
              {tier.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm text-muted">
                  <span class="text-teal-DEFAULT shrink-0 mt-0.5">→</span>
                  {item}
                </li>
              ))}
            </ul>
            <a href={tier.href} class="btn-teal mt-2 justify-center !text-sm">
              {tier.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── CUSTOM ENTERPRISE ─────────────────────────── -->
  <section class="py-16 bg-[#0c1525]">
    <div class="container-mid">
      <div class="card teal-hover border-teal-DEFAULT/30 text-center p-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Enterprise</span>
        <h2 class="font-heading text-2xl md:text-3xl text-light mb-4">Custom Enterprise Engagements</h2>
        <p class="text-muted max-w-xl mx-auto mb-8">
          For organizations requiring multi-department implementation, enterprise licensing of the UNMASK system,
          or long-term embedded partnership, proposal-based scope is available.
          All custom engagements require an Executive Briefing before scoping.
        </p>
        <a href="/structural-burnout/briefing" class="btn-teal">Begin the Briefing Process →</a>
      </div>
    </div>
  </section>


  <!-- ─── SIGNATURE TALKS ───────────────────────────── -->
  <section id="speaking" class="section-pad">
    <div class="container-wide">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">2026 Signature Talks</span>
        <h2 class="font-heading text-3xl text-light">Signature Speaking Platform</h2>
        <p class="text-muted max-w-2xl mx-auto mt-4">
          Premium, practical talks for leadership conferences, associations, universities, nonprofits,
          and mid-market organizations preparing people and systems for AI-era change.
        </p>
      </div>
      <div class="space-y-3 max-w-3xl mx-auto">
        {[
          { num: '01', title: 'AI Accelerates What Exists: Preparing Organizations for the Human x AI Workforce Alliance', desc: 'Helps leaders understand how AI exposes and accelerates existing patterns of burnout, hidden labor, decision friction, authority gaps, and cultural debt.' },
          { num: '02', title: 'The Frictionless Manager: Equipping Managers to Lead the Human x AI Workforce Alliance', desc: 'Introduces the UNMASK framework as a practical leadership architecture for reducing structural drag, pacing AI implementation, and sustaining human judgment and purpose.' },
          { num: '03', title: 'Stop the Strain Transfer: Why Your Best Leaders Are Burning Out', desc: 'Shows how organizations redistribute unresolved structural strain onto high-capacity people, and what leaders can recalibrate instead.' },
          { num: '04', title: 'The Hidden Labor Map: What Your Org Chart Cannot See', desc: 'Names the invisible labor, emotional load, translation work, and repair functions that keep organizations running but rarely receive authority or protection.' },
          { num: '05', title: 'Responsibility Without Authority: The Leadership Gap AI Will Expose', desc: 'Examines how authority gaps create implementation drag, masked leadership, and decision bottlenecks in the AI-era workplace.' },
        ].map((talk) => (
          <div class="flex items-start gap-5 card teal-hover animate-on-scroll">
            <span class="font-heading text-4xl text-teal-DEFAULT/25 font-bold leading-none mt-1 shrink-0">{talk.num}</span>
            <div>
              <p class="font-heading text-light font-semibold mb-1">"{talk.title}"</p>
              <p class="text-muted text-sm">{talk.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Calendar CTA for speaking -->
      <div class="mt-12 max-w-2xl mx-auto card border-teal-DEFAULT/40 bg-teal-glow p-8 text-center animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Schedule a Speaking Conversation</span>
        <h3 class="font-heading text-xl text-light font-semibold mb-3">
          Ready to bring one of these talks to your event?
        </h3>
        <p class="text-muted text-sm mb-6 max-w-sm mx-auto">
          Speaking inquiries begin with an Executive Briefing so the scope, audience, and outcomes can be aligned before booking.
        </p>
        <a
          href="/structural-burnout/briefing"
          class="btn-teal !text-base"
        >
          Request Executive Briefing →
        </a>
        <p class="text-muted text-xs mt-4">
          Speaking and workshop scope available after Executive Briefing
        </p>
      </div>
    </div>
  </section>


  <!-- ─── BOOKING TERMS (below speaking, trimmed) ──────── -->
  <section class="bg-surface border-y border-border py-6">
    <div class="container-wide">
      <p class="text-center text-xs font-body font-bold uppercase tracking-widest text-muted mb-4">Booking Terms</p>
      <div class="flex flex-wrap gap-x-10 gap-y-3 justify-center text-sm text-muted">
        {[
          '50% speaking fee deposit at signing',
          'Balance due 7 days prior',
          'Virtual engagements scoped separately',
          'Travel billed at actual cost or agreed terms',
          'Signed agreement required for all engagements',
        ].map((term) => (
          <span class="flex items-center gap-2">
            <span class="text-teal-DEFAULT font-bold">✓</span>
            {term}
          </span>
        ))}
      </div>
    </div>
  </section>

</Layout>
