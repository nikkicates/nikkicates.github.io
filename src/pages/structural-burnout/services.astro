---
import Layout from '../../layouts/Layout.astro';

const tiers = [
  {
    tag: 'Keynote',
    name: 'Reading the Room Before the Room Breaks',
    price: 'From $12,500',
    duration: '60–90 min keynote / Workshop format available',
    desc: 'The anchor keynote for conferences, associations, and corporate events. Equips leaders to diagnose the structural conditions AI acceleration is already exposing before those conditions become a crisis. Submitted to GOSHRM, Florida Restaurant Show, FRLA Summit, and ACHE Central Florida.',
    includes: [
      'Pre-event discovery call and audience alignment',
      'Custom talk arc for event theme and audience',
      'Covers structural burnout, hidden labor, decision friction, and authority gaps',
      'Post-keynote digital resource or reflection guide for attendees',
      'Workshop format available from $15,000',
      'Travel and hospitality requirements apply',
    ],
    cta: 'Inquire About Speaking',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'Keynote',
    name: 'AI Accelerates What Exists: Preparing Organizations for the Human x AI Workforce Alliance',
    price: 'From $12,500',
    duration: '60–90 min keynote',
    desc: 'Helps leaders understand how AI exposes and accelerates existing patterns of burnout, hidden labor, decision friction, authority gaps, and cultural debt. Built for executive audiences navigating AI mandates without adequate human architecture.',
    includes: [
      'Pre-event discovery call',
      'Custom talk arc aligned to event theme and audience',
      'Audience leaves with a clearer understanding of what AI reveals and what must be recalibrated',
      'Post-keynote digital resource for attendees',
      'Travel and hospitality requirements apply',
    ],
    cta: 'Inquire About Speaking',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'Keynote / Workshop',
    name: 'The Frictionless Manager: Equipping Managers to Lead the Human x AI Workforce Alliance',
    price: 'From $12,500',
    duration: '60–90 min keynote / Workshop format available',
    desc: 'A practical session introducing the UNMASK framework as a leadership architecture for reducing structural drag, pacing AI implementation, and sustaining human judgment and purpose in the Human x AI workplace.',
    includes: [
      'Pre-event discovery call',
      'UNMASK framework introduction for manager-facing audiences',
      'DISC-informed communication and behavioral difference mapping',
      'AI adoption pacing, advocacy upward, and responsibility-authority alignment',
      'Workshop format available from $15,000',
    ],
    cta: 'Inquire About Speaking',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'Group Training',
    name: 'Frictionless Manager Bootcamp — Open Cohort',
    price: '$1,497 per seat (Founding Rate)',
    duration: 'Day-and-a-half · 24 seats maximum',
    desc: 'Group training for managers and senior leaders navigating the Human x AI workplace. Quarterly cohort format. Founding cohort launches early October 2026 in Orlando, Florida. This is the founding rate. Price increases to $1,750 for cohort two. Participants leave with the UNMASK diagnostic language, a structural friction map of their own team, and a 90-day recalibration rhythm.',
    includes: [
      'UNMASK Leadership Architecture training',
      'DISC behavioral assessment and facilitated debrief',
      'Structural burnout and hidden labor mapping',
      'Responsibility-authority alignment review',
      'AI adoption pacing and implementation rhythm',
      '90-day recalibration plan',
      'Post-bootcamp integration support',
    ],
    cta: 'Register Interest',
    href: '/bootcamp',
    featured: true,
  },
  {
    tag: 'Corporate Training',
    name: 'Frictionless Manager Bootcamp — Corporate Onsite',
    price: '$12,500–$15,000',
    duration: 'Day-and-a-half · Delivered at client location',
    desc: 'The full Frictionless Manager Bootcamp delivered onsite for an intact leadership team. Designed for organizations that need their managers to build shared language, diagnostic capacity, and a structural recalibration plan together. First corporate delivery targeted Q4 2026.',
    includes: [
      'Pre-engagement intake and organizational context review',
      'Full UNMASK Leadership Architecture training for the team',
      'DISC behavioral assessment and team-level debrief',
      'Structural burnout and hidden labor mapping for the organization',
      'Responsibility-authority alignment review',
      'Team-level 90-day recalibration plan',
      'Post-engagement integration notes',
    ],
    cta: 'Request Corporate Briefing',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'Group Workshop',
    name: 'UNMASK Facilitated Group Workshop',
    price: '$6,500–$8,500',
    duration: 'Half-Day · Leadership team format',
    desc: 'A half-day facilitated diagnostic experience for leadership teams. Uses the UNMASK framework to surface structural friction, hidden labor, and responsibility-authority gaps before the next initiative lands. Packaging complete Q3 2026. First delivery targeted Q4 2026.',
    includes: [
      'Pre-workshop organizational intake',
      'UNMASK pillar diagnostic across the leadership team',
      'Structural friction and hidden labor mapping',
      'Responsibility-authority alignment review',
      'Shared recalibration priorities and next steps',
      'Post-workshop integration notes',
    ],
    cta: 'Request Workshop Briefing',
    href: '/structural-burnout/briefing',
  },
  {
    tag: 'Strategic Advisory',
    name: 'Strategic Advisory',
    price: 'By inquiry only',
    duration: 'Scope determined after Executive Briefing',
    desc: 'For senior executives and organizations that require direct strategic counsel from Nikki Cates on AI-era operating changes, structural recalibration, and human sustainability priorities. This is a high-touch, exclusive engagement. Not mass-marketed.',
    includes: [
      'Direct access to Nikki Cates',
      'Strategic counsel on AI-era operating priorities',
      'Structural recalibration guidance',
      'Human sustainability and leadership architecture review',
      'Scope and cadence determined after Executive Briefing',
    ],
    cta: 'Request Advisory Briefing',
    href: '/structural-burnout/briefing',
  },
];

const categories = [
  'AI-era leadership strategy',
  'Human x AI workforce readiness',
  'Frictionless Manager training',
  'Group diagnostics and workshops',
  'Structural burnout and hidden labor',
  'Responsibility-authority alignment',
  'UNMASK Leadership Architecture',
  'Keynotes and speaking engagements',
];
---

<Layout
  title="Services - Strategic Transformations"
  description="Speaking, group training, workshops, and strategic advisory for AI-era organizations preparing for the Human x AI workforce alliance."
  section="st"
  accentColor="teal"
>

  <!-- ─── HERO ─────────────────────────────────────── -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0 bg-st-gradient"></div>
    <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-teal-DEFAULT"></div>
    <div class="container-mid relative z-10 text-center">
      <h1 class="font-heading text-4xl md:text-6xl text-light font-bold mb-5 animate-on-scroll">
        Recalibrate the structure<br/>AI acceleration exposes.
      </h1>
      <p class="text-muted text-lg max-w-2xl mx-auto mb-8 animate-on-scroll" style="animation-delay:0.1s">
        Strategic Transformations delivers group training, keynote speaking, and exclusive strategic advisory
        for organizations diagnosing and recalibrating the human and structural strain AI acceleration reveals.
      </p>
      <a href="/structural-burnout/briefing" class="btn-teal animate-on-scroll" style="animation-delay:0.2s">
        Request Executive Briefing →
      </a>
    </div>
  </section>


  <!-- ─── POSITIONING CATEGORIES ───────────────────── -->
  <section class="py-14 bg-[#0c1525] border-y border-border">
    <div class="container-wide">
      <div class="text-center mb-8 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Strategic Transformation Categories</span>
        <h2 class="font-heading text-2xl md:text-3xl text-light mb-4">
          Built for leaders preparing the Human x AI workforce alliance.
        </h2>
        <p class="text-muted max-w-3xl mx-auto">
          Nikki Cates works at the intersection of AI-era leadership, structural burnout,
          organizational diagnostics, behavioral science, emotional intelligence, spiritual intelligence,
          and human sustainability.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {categories.map((category) => (
          <div class="card teal-hover py-4 px-5 animate-on-scroll">
            <p class="text-light text-sm font-semibold">{category}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── TIERS ─────────────────────────────────────── -->
  <section class="section-pad">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {tiers.map((tier) => (
          <div class={`card teal-hover flex flex-col gap-4 relative animate-on-scroll ${tier.featured ? 'border-teal-DEFAULT/60 bg-teal-glow' : ''}`}>
            {tier.featured && (
              <div class="absolute -top-3 left-5">
                <span class="bg-teal-DEFAULT text-[#0f172a] text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-sm font-body">
                  Founding Cohort · October 2026
                </span>
              </div>
            )}
            <div class="flex items-start justify-between gap-4">
              <div>
                <span class="st-tag text-xs mb-2 inline-flex">{tier.tag}</span>
                <h2 class="font-heading text-xl text-light font-bold">{tier.name}</h2>
              </div>
              <div class="text-right shrink-0">
                <p class="font-body text-teal-DEFAULT font-bold text-sm">{tier.price}</p>
                <p class="text-muted text-xs mt-1">{tier.duration}</p>
              </div>
            </div>
            <p class="text-muted text-sm leading-relaxed">{tier.desc}</p>
            <ul class="space-y-2 flex-1">
              {tier.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm text-muted">
                  <span class="text-teal-DEFAULT shrink-0 mt-0.5">→</span>
                  {item}
                </li>
              ))}
            </ul>
            <a href={tier.href} class="btn-teal mt-2 justify-center !text-sm">
              {tier.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── COMING 2027 ──────────────────────────────── -->
  <section class="py-16 bg-[#0c1525] border-y border-border">
    <div class="container-mid">
      <div class="card border-teal-DEFAULT/20 text-center p-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Coming 2027</span>
        <h2 class="font-heading text-2xl md:text-3xl text-light mb-4">IP Licensing and Train-the-Trainer Certification</h2>
        <p class="text-muted max-w-xl mx-auto mb-6">
          The UNMASK framework will be available for organizational licensing and internal facilitator certification
          beginning in 2027. Train-the-Trainer Certification launches Q1 2027. Organizational Framework Licensing
          launches Q2 2027. Organizations interested in early access can begin the conversation now.
        </p>
        <a href="/structural-burnout/briefing" class="btn-outline-teal">Express Early Interest →</a>
      </div>
    </div>
  </section>


  <!-- ─── SIGNATURE TALKS ───────────────────────────── -->
  <section id="speaking" class="section-pad">
    <div class="container-wide">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">2026 Signature Talks</span>
        <h2 class="font-heading text-3xl text-light">Signature Speaking Platform</h2>
        <p class="text-muted max-w-2xl mx-auto mt-4">
          Premium, practical talks for leadership conferences, associations, healthcare and hospitality organizations,
          and mid-market companies preparing people and systems for AI-era change.
        </p>
      </div>
      <div class="space-y-3 max-w-3xl mx-auto">
        {[
          { num: '01', title: 'Reading the Room Before the Room Breaks', desc: 'The anchor keynote. Equips leaders to diagnose the structural conditions AI acceleration is already exposing before those conditions become a crisis. Submitted to GOSHRM, Florida Restaurant Show, FRLA Summit, and ACHE Central Florida.' },
          { num: '02', title: 'AI Accelerates What Exists: Preparing Organizations for the Human x AI Workforce Alliance', desc: 'Helps leaders understand how AI exposes and accelerates existing patterns of burnout, hidden labor, decision friction, authority gaps, and cultural debt.' },
          { num: '03', title: 'The Frictionless Manager: Equipping Managers to Lead the Human x AI Workforce Alliance', desc: 'Introduces the UNMASK framework as a practical leadership architecture for reducing structural drag, pacing AI implementation, and sustaining human judgment and purpose.' },
          { num: '04', title: 'Stop the Strain Transfer: Why Your Best Leaders Are Burning Out', desc: 'Shows how organizations redistribute unresolved structural strain onto high-capacity people, and what leaders can recalibrate instead.' },
          { num: '05', title: 'The Hidden Labor Map: What Your Org Chart Cannot See', desc: 'Names the invisible labor, emotional load, translation work, and repair functions that keep organizations running but rarely receive authority or protection.' },
          { num: '06', title: 'Responsibility Without Authority: The Leadership Gap AI Will Expose', desc: 'Examines how authority gaps create implementation drag, masked leadership, and decision bottlenecks in the AI-era workplace.' },
        ].map((talk) => (
          <div class="flex items-start gap-5 card teal-hover animate-on-scroll">
            <span class="font-heading text-4xl text-teal-DEFAULT/25 font-bold leading-none mt-1 shrink-0">{talk.num}</span>
            <div>
              <p class="font-heading text-light font-semibold mb-1">"{talk.title}"</p>
              <p class="text-muted text-sm">{talk.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Calendar CTA for speaking -->
      <div class="mt-12 max-w-2xl mx-auto card border-teal-DEFAULT/40 bg-teal-glow p-8 text-center animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Schedule a Speaking Conversation</span>
        <h3 class="font-heading text-xl text-light font-semibold mb-3">
          Ready to bring one of these talks to your event?
        </h3>
        <p class="text-muted text-sm mb-6 max-w-sm mx-auto">
          Speaking inquiries begin with an Executive Briefing so the scope, audience, and outcomes can be aligned before booking.
        </p>
        <a
          href="/structural-burnout/briefing"
          class="btn-teal !text-base"
        >
          Request Executive Briefing →
        </a>
        <p class="text-muted text-xs mt-4">
          Speaking and workshop scope available after Executive Briefing
        </p>
      </div>
    </div>
  </section>


  <!-- ─── BOOKING TERMS ──────────────────────────────── -->
  <section class="bg-surface border-y border-border py-6">
    <div class="container-wide">
      <p class="text-center text-xs font-body font-bold uppercase tracking-widest text-muted mb-4">Booking Terms</p>
      <div class="flex flex-wrap gap-x-10 gap-y-3 justify-center text-sm text-muted">
        {[
          '50% speaking fee deposit at signing',
          'Balance due 7 days prior',
          'Virtual engagements scoped separately',
          'Travel billed at actual cost or agreed terms',
          'Signed agreement required for all engagements',
        ].map((term) => (
          <span class="flex items-center gap-2">
            <span class="text-teal-DEFAULT font-bold">✓</span>
            {term}
          </span>
        ))}
      </div>
    </div>
  </section>

</Layout>
