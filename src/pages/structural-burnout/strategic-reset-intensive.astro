---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Strategic Reset Intensive — Group Reset for Structural Burnout and AI-Era Strain"
  description="A Strategic Transformations small-group intensive for women navigating over-responsibility, under-support, and structural strain in the AI era."
  section="st"
  accentColor="teal"
>
  <!-- HERO -->
  <section class="relative min-h-[78vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-st-gradient"></div>
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 70% 60% at 82% 32%, rgba(13,148,136,0.12) 0%, transparent 60%);"
    ></div>
    <div
      class="absolute inset-0 opacity-[0.08]"
      style="background-image: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 32px 32px;"
    ></div>
    <div
      class="absolute right-[-6rem] top-20 h-64 w-64 rotate-12 border border-teal-DEFAULT/20"
      style="clip-path: polygon(25% 6.7%, 75% 6.7%, 100% 50%, 75% 93.3%, 25% 93.3%, 0% 50%);"
    ></div>
    <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-teal-DEFAULT"></div>

    <div class="container-wide relative z-10 py-24">
      <div class="max-w-4xl">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="st-tag inline-flex">Strategic Transformations</span>
          <span class="text-[10px] uppercase tracking-[0.24em] text-muted border border-border rounded-full px-3 py-1">
            URI-rooted leadership architecture
          </span>
        </div>

        <h1 class="font-heading text-4xl md:text-6xl text-light font-bold leading-tight mb-6 animate-on-scroll">
          A Strategic Reset Intensive for women who refuse to be the
          <span class="text-teal-DEFAULT italic">load-bearing wall</span>
          of the AI era.
        </h1>

        <p
          class="text-light text-lg md:text-xl leading-relaxed max-w-3xl mb-4 animate-on-scroll"
          style="animation-delay:0.08s"
        >
          For women navigating over-responsibility, under-support, and the pressure to keep performing in systems that were never designed for their sustainability.
        </p>

        <p
          class="text-muted text-base leading-relaxed max-w-3xl mb-8 animate-on-scroll"
          style="animation-delay:0.12s"
        >
          In this small-group reset, you will leave with a personal AI governance boundary, a practical AI operating system, and an execution plan that turns uncertainty into movement without sacrificing your nervous system, your integrity, or your voice.
        </p>

        <div class="mb-8 animate-on-scroll" style="animation-delay:0.16s">
          <p class="text-xs uppercase tracking-[0.24em] text-muted mb-2">
            A Strategic Transformations diagnostic experience
          </p>
          <p class="text-sm text-light">
            Rooted in the liberation-centered leadership architecture of URI
          </p>
        </div>

        <div class="flex flex-wrap gap-4 animate-on-scroll" style="animation-delay:0.2s">
          <a href="#inquiry-form" class="btn-teal">Ask About the Next Cohort</a>
          <a href="#format" class="btn-outline-teal">See the group format</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT THIS NAMES -->
  <section id="diagnostic" class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">What this names</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          This is not generic burnout support.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-5xl mx-auto">
        {[
          'You are being held responsible for more outcomes than you have the authority, support, or decision rights to carry.',
          'You are absorbing hidden labor, cleanup work, and emotional strain that rarely gets named and almost never gets resourced.',
          'You may be performing competence inside systems that depend on your overfunctioning.',
          'AI may be increasing the speed, noise, and oversight demands without reducing the burden on your body, judgment, or capacity.',
        ].map((item) => (
          <div class="card teal-hover animate-on-scroll">
            <div
              class="mb-4 h-10 w-10 border border-teal-DEFAULT/40 bg-teal-DEFAULT/5"
              style="clip-path: polygon(25% 6.7%, 75% 6.7%, 100% 50%, 75% 93.3%, 25% 93.3%, 0% 50%);"
            ></div>
            <p class="text-light leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FORMAT -->
  <section id="format" class="section-pad relative overflow-hidden">
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 60% 70% at 50% 50%, rgba(13,148,136,0.06) 0%, transparent 70%);"
    ></div>
    <div class="container-wide relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="animate-on-scroll">
          <span class="st-tag mb-5 inline-flex">Format</span>
          <h2 class="font-heading text-3xl md:text-4xl text-light mb-6">
            Small-group first. VIP support available.
          </h2>
          <p class="text-muted leading-relaxed mb-4">
            The Strategic Reset Intensive is designed as a curated small-group experience for women who need more than motivation and less isolation. The group format helps participants recognize shared structural patterns, recover language for what they have been carrying, and move forward with more clarity and less self-blame.
          </p>
          <p class="text-muted leading-relaxed mb-8">
            A limited VIP add-on is available for women who want private follow-up, tailored application, or a deeper 1:1 reset after the group intensive.
          </p>
        </div>

        <div class="space-y-4 animate-on-scroll" style="animation-delay:0.12s">
          {[
            {
              title: 'Curated Small Group',
              desc: 'A carefully held cohort experience designed for reflection, pattern recognition, strategic clarity, and shared language without becoming a generic support circle.',
            },
            {
              title: 'Personal AI Governance Boundary',
              desc: 'A clear boundary for how you will and will not engage AI, speed, availability, and digital overreach in this season.',
            },
            {
              title: 'Practical AI Operating System',
              desc: 'A grounded approach to using AI as support rather than extraction, including where it helps, where it harms, and what needs guardrails.',
            },
            {
              title: 'VIP Add-On Option',
              desc: 'A private follow-up pathway for participants who want personalized strategy, deeper application, or direct 1:1 support after the cohort experience.',
            },
          ].map((item) => (
            <div class="p-5 rounded-md border border-border hover:border-teal-DEFAULT/40 transition-colors bg-surface/50">
              <p class="font-heading text-light font-semibold text-lg mb-2">{item.title}</p>
              <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT YOU WALK AWAY WITH -->
  <section class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">What you walk away with</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          Clarity, boundaries, and a way forward.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
        {[
          {
            title: 'AI Governance Boundary',
            desc: 'A clearer line around how you will engage AI without sacrificing judgment, capacity, or values.',
          },
          {
            title: 'Practical Operating System',
            desc: 'A grounded approach to using AI and other supports in ways that reduce drag rather than intensify it.',
          },
          {
            title: 'Execution Plan',
            desc: 'A realistic next-step plan for what to stop carrying, what to renegotiate, and what to move on now.',
          },
          {
            title: 'Included Resource',
            desc: 'UNMASK Blueprint Vol. 1: Deconstruction of the Grind, including the accompanying interactive web experience.',
          },
        ].map((item) => (
          <div class="card teal-hover animate-on-scroll">
            <p class="font-heading text-light text-xl mb-3">{item.title}</p>
            <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="section-pad">
    <div class="container-wide">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">What’s included</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light">
          A focused, high-clarity cohort experience.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
        <div class="card teal-hover animate-on-scroll">
          <p class="text-teal-DEFAULT text-xs uppercase tracking-[0.22em] mb-3">Phase 1</p>
          <p class="font-heading text-light text-xl mb-3">Diagnostic Pre-Work</p>
          <p class="text-muted text-sm leading-relaxed">
            A short intake and reflection process to surface burnout patterns, authority mismatch, hidden labor, masking pressure, and AI strain before the live intensive.
          </p>
        </div>

        <div class="card teal-hover animate-on-scroll">
          <p class="text-teal-DEFAULT text-xs uppercase tracking-[0.22em] mb-3">Phase 2</p>
          <p class="font-heading text-light text-xl mb-3">Live Group Reset</p>
          <p class="text-muted text-sm leading-relaxed">
            One 2-hour strategic small-group intensive designed to help participants name structural strain, clarify current reality, and identify the highest-leverage moves forward.
          </p>
        </div>

        <div class="card teal-hover animate-on-scroll">
          <p class="text-teal-DEFAULT text-xs uppercase tracking-[0.22em] mb-3">Phase 3</p>
          <p class="font-heading text-light text-xl mb-3">Reset Tools</p>
          <p class="text-muted text-sm leading-relaxed">
            A practical reset framework including AI boundaries, execution priorities, and next-step prompts participants can use immediately after the session.
          </p>
        </div>

        <div class="card teal-hover animate-on-scroll">
          <p class="text-teal-DEFAULT text-xs uppercase tracking-[0.22em] mb-3">Included</p>
          <p class="font-heading text-light text-xl mb-3">UNMASK Vol. 1</p>
          <p class="text-muted text-sm leading-relaxed">
            The UNMASK Blueprint Vol. 1: Deconstruction of the Grind, including the accompanying interactive web experience.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BEST FIT + PRICING -->
  <section class="section-pad bg-[#0c1525]">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="animate-on-scroll">
          <span class="st-tag mb-5 inline-flex">Best fit</span>
          <h2 class="font-heading text-3xl md:text-4xl text-light mb-6">
            This intensive is for you if…
          </h2>
          <div class="space-y-3 text-muted">
            <p>• You are navigating burnout, transition, or reinvention and need more than encouragement.</p>
            <p>• You have been carrying too much without enough authority, support, or relief.</p>
            <p>• You suspect the issue is structural, but need language, boundaries, and a plan.</p>
            <p>• You want a group setting that offers depth, clarity, and strategic reflection rather than generic networking.</p>
            <p>• You want to engage AI without letting it erase your judgment, humanity, or voice.</p>
          </div>
        </div>

        <div class="animate-on-scroll" style="animation-delay:0.1s">
          <span class="st-tag mb-5 inline-flex">Investment</span>
          <div class="card border-teal-DEFAULT/30 bg-teal-DEFAULT/5">
            <p class="text-muted text-sm uppercase tracking-[0.22em] mb-3">Public pricing</p>
            <p class="font-heading text-light text-3xl mb-4">Founding cohort pricing available</p>
            <p class="text-muted leading-relaxed mb-4">
              Group and VIP add-on options are available. Final investment details are shared with aligned participants during inquiry and cohort enrollment.
            </p>
            <p class="text-muted leading-relaxed mb-6">
              VIP add-on support is limited and offered as a premium follow-up pathway after the group intensive.
            </p>
            <a href="#inquiry-form" class="btn-teal w-full text-center">Ask About the Next Cohort</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INQUIRY FORM -->
  <section id="inquiry-form" class="section-pad">
    <div class="container-narrow">
      <div class="text-center mb-10 animate-on-scroll">
        <span class="st-tag mb-4 inline-flex">Protected Entry Point</span>
        <h2 class="font-heading text-3xl md:text-4xl text-light mb-4">
          Strategic Reset Intensive Inquiry
        </h2>
        <p class="text-muted text-base max-w-2xl mx-auto mb-4">
          This short inquiry helps determine fit for the next curated Strategic Reset Intensive cohort.
        </p>
        <p class="text-muted text-sm max-w-xl mx-auto">
          You do not need to keep carrying this season the way you have been. This inquiry helps determine whether the Strategic Reset Intensive is the right next step for you and whether you may also want to hear about the VIP add-on.
        </p>
      </div>

      <form id="reset-form" class="space-y-10" novalidate>
        <!-- SECTION 1 -->
        <fieldset class="card border-teal-DEFAULT/20">
          <legend class="font-heading text-light text-xl font-semibold mb-1 px-2">
            01 — Contact + Current Season
          </legend>
          <p class="text-muted text-sm mb-6 px-2">Tell me who you are and what season you are in.</p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="form-group">
              <label class="form-label" for="full-name">Full Name *</label>
              <input class="form-input" id="full-name" name="fullName" type="text" placeholder="Your full name" required />
            </div>

            <div class="form-group">
              <label class="form-label" for="email">Email Address *</label>
              <input class="form-input" id="email" name="email" type="email" placeholder="you@example.com" required />
            </div>

            <div class="form-group md:col-span-2">
              <label class="form-label" for="current-season">Current Role / Season *</label>
              <select class="form-select" id="current-season" name="currentSeason" required>
                <option value="">Select one</option>
                <option>employed professional</option>
                <option>founder / business owner</option>
                <option>in transition</option>
                <option>currently unemployed / re-entering</option>
                <option>other</option>
              </select>
            </div>
          </div>
        </fieldset>

        <!-- SECTION 2 -->
        <fieldset class="card border-teal-DEFAULT/20">
          <legend class="font-heading text-light text-xl font-semibold mb-1 px-2">
            02 — What You Are Navigating
          </legend>
          <p class="text-muted text-sm mb-6 px-2">Help me understand the shape of the strain.</p>

          <div class="space-y-6">
            <div class="form-group">
              <label class="form-label">What best describes what you are navigating right now? *</label>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3">
                {[
                  'burnout',
                  'over-responsibility',
                  'hidden labor',
                  'leadership strain',
                  'career transition',
                  'founder transition / reinvention',
                  'AI overwhelm or confusion',
                  'lack of authority or support',
                  'difficulty knowing what to do next',
                ].map((item) => (
                  <label class="flex items-start gap-3 p-3 bg-surface border border-border rounded-md text-sm text-muted">
                    <input
                      type="checkbox"
                      name="currentChallenges"
                      value={item}
                      class="mt-1 accent-teal-DEFAULT"
                    />
                    <span>{item}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="heaviest-right-now">What feels heaviest right now? *</label>
              <textarea
                class="form-textarea"
                id="heaviest-right-now"
                name="heaviestRightNow"
                placeholder="Tell me what feels most difficult, costly, or unsustainable right now."
                required
              ></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="authority-mismatch">
                Where are you carrying more outcomes than you have the authority, support, or decision rights to hold? *
              </label>
              <textarea
                class="form-textarea"
                id="authority-mismatch"
                name="authorityMismatch"
                placeholder="Describe where responsibility is outrunning authority in your current situation."
                required
              ></textarea>
            </div>
          </div>
        </fieldset>

        <!-- SECTION 3 -->
        <fieldset class="card border-teal-DEFAULT/20">
          <legend class="font-heading text-light text-xl font-semibold mb-1 px-2">
            03 — AI + Offer Fit
          </legend>
          <p class="text-muted text-sm mb-6 px-2">Help me understand how AI and timing are showing up for you.</p>

          <div class="grid grid-cols-1 gap-5">
            <div class="form-group">
              <label class="form-label" for="ai-role">What role is AI currently playing in your life or work? *</label>
              <select class="form-select" id="ai-role" name="aiRole" required>
                <option value="">Select one</option>
                <option>helpful support</option>
                <option>pressure to do more faster</option>
                <option>confusion / uncertainty</option>
                <option>cleanup burden</option>
                <option>not really using it yet</option>
                <option>mixed / all of the above</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="desired-value">
                What would make this reset feel timely and valuable for you right now? *
              </label>
              <textarea
                class="form-textarea"
                id="desired-value"
                name="desiredValue"
                placeholder="Tell me what you need most from a reset like this."
                required
              ></textarea>
            </div>

            <div class="form-group">
              <label class="form-label" for="vip-interest">
                Are you interested in the group intensive only, or would you also like details about the VIP add-on? *
              </label>
              <select class="form-select" id="vip-interest" name="vipInterest" required>
                <option value="">Select one</option>
                <option>group intensive only</option>
                <option>group intensive + VIP details</option>
                <option>not sure yet</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label" for="anything-else">Anything else you want me to know before reviewing your inquiry?</label>
              <textarea
                class="form-textarea"
                id="anything-else"
                name="anythingElse"
                placeholder="Anything relevant that would help me understand your context better."
              ></textarea>
            </div>
          </div>
        </fieldset>

        <!-- CONSENT -->
        <div class="bg-surface/50 border border-border rounded-md p-5 text-sm text-muted">
          <p>
            <span class="text-light font-semibold">Important:</span>
            Submitting this form begins a conversation. This is a curated cohort, so each inquiry is reviewed for fit before next-step details are shared. Submission does not guarantee enrollment.
          </p>
        </div>

        <!-- SUBMIT -->
        <div class="text-center">
          <button
            type="submit"
            id="submit-btn"
            class="btn-teal text-base px-10 py-4 inline-flex items-center gap-2"
          >
            <span id="submit-label">Ask About the Next Cohort</span>
            <svg id="submit-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none">
              <circle
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="3"
                stroke-dasharray="30 60"
                stroke-linecap="round"
              />
            </svg>
          </button>
        </div>

        <!-- STATUS -->
        <div id="form-status" class="hidden text-center p-6 rounded-md border"></div>
      </form>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="py-16 relative overflow-hidden bg-[#0c1525]">
    <div class="container-mid relative z-10 text-center animate-on-scroll">
      <h2 class="font-heading text-3xl md:text-4xl text-light mb-4">
        The next step is not more self-blame.
      </h2>
      <p class="text-muted mb-8 max-w-2xl mx-auto">
        It is a Strategic Reset that helps you identify what is structural, what is recoverable, and what must change so your next season is built with more truth, more clarity, and more sovereignty.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#inquiry-form" class="btn-teal">Ask About the Next Cohort</a>
        <a href="/books/" class="btn-outline-teal">Explore the UNMASK Blueprint</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('reset-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const label = document.getElementById('submit-label') as HTMLElement;
  const spinner = document.getElementById('submit-spinner') as HTMLElement;
  const status = document.getElementById('form-status') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    btn.disabled = true;
    label.textContent = 'Submitting...';
    spinner.classList.remove('hidden');

    const formData = new FormData(form);
    const rawData = Object.fromEntries(formData.entries());

    const challengeValues = formData.getAll('currentChallenges');

    const data = {
      ...rawData,
      currentChallenges: challengeValues,
      formType: 'strategic-reset-intensive',
      source: 'nikkicates.github.io',
    };

    try {
      // Replace with your actual GHL inbound webhook URL
      const GHL_WEBHOOK =
        'https://services.leadconnectorhq.com/hooks/35XiTsvy0Kt7TRNBabas/webhook-trigger/45d555d1-61ba-4631-9727-23de3875cc0f;

      await fetch(GHL_WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        mode: 'no-cors',
      });

      form.classList.add('hidden');
      status.classList.remove('hidden');
      status.className = 'text-center p-6 rounded-md border border-teal-DEFAULT/40 bg-teal-glow';
      status.innerHTML = `
        <p class="font-heading text-xl text-teal-DEFAULT font-semibold mb-2">Your inquiry has been received.</p>
        <p class="text-muted text-sm max-w-2xl mx-auto">
          Thank you for reaching out about the Strategic Reset Intensive.
          This is a curated small-group experience, so each inquiry is reviewed for fit before the next cohort is finalized.
          If it looks aligned, you’ll receive next-step details for the upcoming group along with information about the optional VIP add-on if you requested it.
        </p>
        <p class="text-muted text-sm max-w-2xl mx-auto mt-4">
          In the meantime, take a breath. The fact that something feels unsustainable does not mean you are failing.
          It may mean you have been carrying what was never meant to rest on you alone.
        </p>
      `;
    } catch (err) {
      btn.disabled = false;
      label.textContent = 'Ask About the Next Cohort';
      spinner.classList.add('hidden');
      status.classList.remove('hidden');
      status.className = 'text-center p-6 rounded-md border border-red-500/40 bg-red-900/10';
      status.innerHTML = `
        <p class="text-red-400 text-sm">
          Something went wrong. Please email
          <a href="mailto:hello@nikkicates.com" class="underline">hello@nikkicates.com</a>
          directly.
        </p>
      `;
    }
  });
</script>
