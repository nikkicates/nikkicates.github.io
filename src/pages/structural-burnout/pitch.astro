---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="bg-zinc-950 text-zinc-100 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 py-20">
      <a href="/structural-burnout" class="inline-flex items-center gap-2 text-teal-400 hover:text-teal-300 mb-12 text-sm">
        ← Back to Structural Burnout
      </a>

      <h1 class="text-5xl md:text-6xl font-bold tracking-tighter mb-10">
        UNMASK Executive Pitch
      </h1>

      <div class="bg-zinc-900 border border-purple-400/30 rounded-3xl p-12 mb-16">
        <h2 class="text-4xl font-bold tracking-tighter mb-6">Seed Capital Opportunity</h2>
        <p class="text-2xl text-zinc-400 mb-8">
          We are seeking <span class="text-white font-semibold">$30,000</span> in seed capital for the UNMASK Engine.
        </p>
      </div>

      <div class="text-center">
        <a href="/structural-burnout/services" class="inline-block px-12 py-6 border border-teal-400 hover:bg-teal-400 hover:text-zinc-950 font-semibold rounded-3xl">
          Explore Engagements
        </a>
      </div>
    </div>
  </div>
</Layout>