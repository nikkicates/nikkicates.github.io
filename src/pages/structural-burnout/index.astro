---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <div class="bg-zinc-950 text-zinc-100 min-h-screen">
    <div class="pt-32 pb-24 px-6 text-center max-w-5xl mx-auto">
      <div class="inline-block px-6 py-2 rounded-full bg-zinc-900 border border-teal-400/30 text-teal-400 text-sm font-bold tracking-widest mb-8">
        LEADERSHIP ARCHITECTURE
      </div>
      
      <h1 class="text-6xl md:text-7xl font-bold tracking-tighter leading-none mb-10">
        Burnout is a <span class="text-teal-400">Design Flaw.</span>
      </h1>
      
      <p class="text-2xl text-zinc-400 max-w-3xl mx-auto">
        Your organization is extracting invisible labor while denying leaders the authority to fix the systems causing it.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-16">
        <a href="/structural-burnout/services" 
           class="px-10 py-6 bg-teal-400 hover:bg-teal-300 text-zinc-950 font-semibold rounded-3xl text-lg transition">
          Start the Structural Audit
        </a>
        <a href="/structural-burnout/briefing" 
           class="px-10 py-6 border border-zinc-700 hover:border-teal-400 font-semibold rounded-3xl text-lg transition">
          Executive Briefing
        </a>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-3 gap-6 pb-24">
      <a href="/structural-burnout/services" class="bg-zinc-900 border border-zinc-800 hover:border-teal-400 p-8 rounded-3xl transition">
        <h3 class="text-2xl font-semibold mb-4">Services & Engagements</h3>
        <p class="text-zinc-400">Keynotes, workshops, URI Formation tracks, and full architectural redesign.</p>
      </a>
      <a href="/structural-burnout/pitch" class="bg-zinc-900 border border-zinc-800 hover:border-purple-400 p-8 rounded-3xl transition">
        <h3 class="text-2xl font-semibold mb-4">Investor Pitch</h3>
        <p class="text-zinc-400">$30k seed opportunity for the UNMASK Engine.</p>
      </a>
      <a href="/structural-burnout/nexus" class="bg-zinc-900 border border-zinc-800 hover:border-teal-400 p-8 rounded-3xl transition">
        <h3 class="text-2xl font-semibold mb-4">Networking Card</h3>
        <p class="text-zinc-400">Quick-access digital business card for events.</p>
      </a>
    </div>
  </div>
</Layout>