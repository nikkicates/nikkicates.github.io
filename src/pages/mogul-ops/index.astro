---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Mogul Ops — Internal Portal"
  description="Mogul Ops is the internal operations portal for the Strategic Transformations and URI ecosystem. Authorized access only."
  section="st"
  accentColor="teal"
>

  <section class="min-h-screen flex items-center justify-center py-16 px-4 relative overflow-hidden">
    <div class="absolute inset-0 bg-[#0f172a]"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 50% 50% at 50% 50%, rgba(13,148,136,0.05) 0%, transparent 65%);"></div>

    <div class="relative z-10 w-full max-w-sm text-center">
      <!-- Icon -->
      <div class="w-16 h-16 rounded-full mx-auto mb-6 flex items-center justify-center border border-teal-DEFAULT/40"
           style="background: rgba(13,148,136,0.1);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>

      <span class="st-tag mb-4 inline-flex">Internal Portal</span>
      <h1 class="font-heading text-2xl text-light font-bold mb-3">Mogul Ops</h1>
      <p class="text-muted text-sm mb-8">
        This portal is for authorized team members and operations staff only.
        If you've reached this page in error, please navigate back to the
        <a href="/" class="text-teal-DEFAULT hover:text-teal-light underline">main site</a>.
      </p>

      <!-- Access form -->
      <form id="ops-form" class="space-y-4" novalidate>
        <div class="form-group text-left">
          <label class="form-label" for="ops-email">Email Address</label>
          <input
            class="form-input"
            id="ops-email"
            name="email"
            type="email"
            placeholder="yourname@strategicunmasking.com"
            required
          />
        </div>
        <div class="form-group text-left">
          <label class="form-label" for="ops-access-code">Access Code</label>
          <input
            class="form-input"
            id="ops-access-code"
            name="code"
            type="password"
            placeholder="••••••••"
            required
          />
        </div>
        <button type="submit" class="btn-teal w-full justify-center mt-2">
          Access Portal →
        </button>
      </form>

      <div id="ops-status" class="hidden mt-5 text-center p-4 rounded-md border"></div>

      <p class="text-muted text-xs mt-8">
        Need access? Contact
        <a href="mailto:nikki@strategicunmasking.com" class="text-teal-DEFAULT hover:underline">
          nikki@strategicunmasking.com
        </a>
      </p>
    </div>
  </section>

</Layout>

<script>
  // This is a placeholder — replace with your actual auth mechanism
  // (GHL portal, custom backend, or GoHighLevel membership area link)
  const form = document.getElementById('ops-form') as HTMLFormElement;
  const status = document.getElementById('ops-status') as HTMLElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // Replace this with your actual portal redirect logic
    status.classList.remove('hidden');
    status.className = 'mt-5 text-center p-4 rounded-md border border-red-500/40 bg-red-900/10';
    status.innerHTML = `<p class="text-red-400 text-sm">Access portal is being configured. Please contact <a href="mailto:nikki@strategicunmasking.com" class="underline">nikki@strategicunmasking.com</a> for access.</p>`;
  });
</script>
