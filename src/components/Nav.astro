---
interface Props {
  section?: 'home' | 'st' | 'uri';
  accentColor?: 'teal' | 'gold';
}
const { section = 'home', accentColor = 'teal' } = Astro.props;

const stLinks = [
  { href: '/structural-burnout/', label: 'Structural Burnout' },
  { href: '/structural-burnout/services', label: 'Services & Pricing' },
  { href: '/structural-burnout/pitch', label: 'Investor Hub' },
];

const connectLinks = [
  { href: '/structural-burnout/nexus', label: 'Nexus Card' },
  { href: 'https://calendar.app.google/1atA8vsgwQhP7bqX6', label: 'Schedule a Call', external: true },
  { href: '/structural-burnout/briefing', label: 'Executive Briefing' },
];
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: rgba(15,23,42,0.92); backdrop-filter: blur(14px); border-bottom: 1px solid rgba(51,65,85,0.4);"
>
  <div class="container-wide">
    <div class="flex items-center justify-between h-20 md:h-22">

      <!-- LOGO -->
      <a href="/" class="flex items-center shrink-0" aria-label="Return to homepage">
        {section === 'home' && (
          <img src="/logos/nc-logo.png" alt="Nikki Cates" width="200" height="44" class="h-24 w-auto" loading="eager" fetchpriority="high" />
        )}
        {section === 'st' && (
          <img src="/logos/st-logo.png" alt="Strategic Transformations" width="220" height="44" class="h-24 w-auto" loading="eager" fetchpriority="high" />
        )}
        {section === 'uri' && (
          <img src="/logos/uri-logo.png" alt="URI" width="200" height="44" class="h-24 w-auto" loading="eager" fetchpriority="high" />
        )}
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Primary navigation">
    <a href="/" class="nav-btn">Home</a>
        <!-- ST Work dropdown -->
        <div class="nav-dropdown-wrap">
          <button class="nav-btn nav-dropdown-trigger" aria-expanded="false" data-dropdown="st-work">
            ST Work
            <svg class="nav-arrow" width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
              <path d="M2 4l4 4 4-4"/>
            </svg>
          </button>
          <div class="nav-dropdown" id="dropdown-st-work" role="menu">
            {stLinks.map(l => (
              <a href={l.href} class="nav-dropdown-item">{l.label}</a>
            ))}
          </div>
        </div>

        <a href="/uri/" class="nav-btn">URI Formation</a>
        <a href="/books/" class="nav-btn">Books</a>
        <a href="/speaker-kit/" class="nav-btn">Speaker Kit</a>

        <!-- Connect dropdown -->
        <div class="nav-dropdown-wrap">
          <button class="nav-btn nav-dropdown-trigger" aria-expanded="false" data-dropdown="connect">
            Connect
            <svg class="nav-arrow" width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
              <path d="M2 4l4 4 4-4"/>
            </svg>
          </button>
          <div class="nav-dropdown" id="dropdown-connect" role="menu">
            {connectLinks.map(l => (
              <a
                href={l.href}
                class="nav-dropdown-item"
                target={l.external ? '_blank' : undefined}
                rel={l.external ? 'noopener' : undefined}
              >
                {l.label}
              </a>
            ))}
          </div>
        </div>

        <a href="/structural-burnout/briefing" class="ml-2 btn-teal !text-sm !py-2 !px-4">
          Request Briefing
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button id="nav-toggle" class="md:hidden flex flex-col gap-[5px] p-2 cursor-pointer" aria-label="Open menu" aria-expanded="false">
        <span class="w-5 h-[2px] bg-light block" id="bar1"></span>
        <span class="w-5 h-[2px] bg-light block" id="bar2"></span>
        <span class="w-5 h-[2px] bg-light block" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="md:hidden hidden flex-col pb-5 px-6 bg-[#0f172a] border-t border-border">
    <p class="text-muted text-xs font-bold uppercase tracking-widest pt-4 pb-2">ST Work</p>
    {stLinks.map(l => (
      <a href={l.href} class="font-body text-sm text-muted py-2.5 border-b border-border/30 hover:text-light transition-colors">{l.label}</a>
    ))}
    <a href="/uri/" class="font-body text-sm text-muted py-2.5 border-b border-border/30 hover:text-light transition-colors">URI Formation</a>
    <a href="/books/" class="font-body text-sm text-muted py-2.5 border-b border-border/30 hover:text-light transition-colors">Books</a>
    <a href="/speaker-kit/" class="font-body text-sm text-muted py-2.5 border-b border-border/30 hover:text-light transition-colors">Speaker Kit</a>
    <p class="text-muted text-xs font-bold uppercase tracking-widest pt-4 pb-2">Connect</p>
    {connectLinks.map(l => (
      <a
        href={l.href}
        class="font-body text-sm text-muted py-2.5 border-b border-border/30 hover:text-light transition-colors"
        target={l.external ? '_blank' : undefined}
        rel={l.external ? 'noopener' : undefined}
      >
        {l.label}
      </a>
    ))}
    <a href="/structural-burnout/briefing" class="btn-teal mt-4 justify-center !text-sm">Request Briefing</a>
  </div>
</header>

<div class="h-20 md:h-22"></div>

<style>
.nav-btn {
  font-family: 'Urbanist', sans-serif;
  font-size: .85rem;
  font-weight: 600;
  color: #94a3b8;
  background: none;
  border: none;
  cursor: pointer;
  padding: .45rem .75rem;
  border-radius: 4px;
  transition: color .15s, background .15s;
  display: flex;
  align-items: center;
  gap: .3rem;
  white-space: nowrap;
  text-decoration: none;
}
.nav-btn:hover { color: #f8fafc; background: rgba(51,65,85,.5); }
.nav-btn.active { color: #f8fafc; }

.nav-arrow {
  transition: transform .2s;
  stroke: currentColor;
  fill: none;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.nav-dropdown-wrap { position: relative; }
.nav-dropdown-trigger[aria-expanded="true"] .nav-arrow { transform: rotate(180deg); }
.nav-dropdown-trigger[aria-expanded="true"] { color: #f8fafc; background: rgba(51,65,85,.5); }

.nav-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  min-width: 190px;
  background: #1e293b;
  border: 1px solid #334155;
  border-radius: 6px;
  padding: .35rem;
  box-shadow: 0 12px 32px rgba(0,0,0,.45);
  display: none;
  flex-direction: column;
  z-index: 200;
}
.nav-dropdown.open { display: flex; }
.nav-dropdown-item {
  font-family: 'Urbanist', sans-serif;
  font-size: .83rem;
  color: #94a3b8;
  padding: .6rem .85rem;
  border-radius: 4px;
  text-decoration: none;
  transition: color .12s, background .12s;
  white-space: nowrap;
}
.nav-dropdown-item:hover { color: #f8fafc; background: rgba(51,65,85,.6); }
</style>

<script>
// ── Click-triggered dropdowns ──────────────────────
document.querySelectorAll('.nav-dropdown-trigger').forEach(btn => {
  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    const id = btn.dataset.dropdown;
    const menu = document.getElementById('dropdown-' + id);
    const isOpen = btn.getAttribute('aria-expanded') === 'true';

    // Close all other dropdowns first
    document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.remove('open'));
    document.querySelectorAll('.nav-dropdown-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));

    if (!isOpen) {
      menu?.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
});

// Close on outside click
document.addEventListener('click', () => {
  document.querySelectorAll('.nav-dropdown').forEach(d => d.classList.remove('open'));
  document.querySelectorAll('.nav-dropdown-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));
});

// Mobile toggle
const toggle = document.getElementById('nav-toggle');
const menu   = document.getElementById('mobile-menu');
const bar1   = document.getElementById('bar1');
const bar2   = document.getElementById('bar2');
const bar3   = document.getElementById('bar3');
let open = false;
toggle?.addEventListener('click', () => {
  open = !open;
  menu?.classList.toggle('hidden', !open);
  menu?.classList.toggle('flex', open);
  toggle.setAttribute('aria-expanded', String(open));
  if (bar1 && bar2 && bar3) {
    bar1.style.transform = open ? 'rotate(45deg) translate(5px,5px)' : '';
    bar2.style.opacity   = open ? '0' : '1';
    bar3.style.transform = open ? 'rotate(-45deg) translate(5px,-5px)' : '';
  }
});

// Scroll shadow
const nav = document.getElementById('site-nav');
window.addEventListener('scroll', () => {
  if (nav) nav.style.boxShadow = window.scrollY > 20 ? '0 4px 30px rgba(0,0,0,.45)' : 'none';
});
</script>
