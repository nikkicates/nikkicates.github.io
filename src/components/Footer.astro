---
interface Props {
  section?: 'home' | 'st' | 'uri';
}
const { section = 'home' } = Astro.props;
const isURI = section === 'uri';
---

<footer class="border-t border-border mt-24 bg-[#0c1525]">
  <div class="container-wide py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="md:col-span-1">
        <p class="font-heading text-lg font-semibold text-light mb-3">
          Nikki <span class={isURI ? 'text-gold' : 'text-teal-DEFAULT'}>Cates</span>
        </p>
        <p class="text-muted text-sm leading-relaxed mb-4">
          Structural Recalibration Strategist · Author · Speaker · Army Veteran
        </p>
        <p class="text-muted text-xs">
          <a href="mailto:nikki@strategicunmasking.com"
             class={`${isURI ? 'text-gold hover:text-gold-light' : 'text-teal-DEFAULT hover:text-teal-light'} transition-colors`}>
            nikki@strategicunmasking.com
          </a>
        </p>
      </div>

      <!-- Strategic Transformations -->
      <div>
        <p class="font-body text-xs font-700 uppercase tracking-widest text-muted mb-4">
          Strategic Transformations
        </p>
        <ul class="space-y-2 text-sm">
          {[
            { href: '/structural-burnout/', label: 'Structural Burnout Hub' },
            { href: '/structural-burnout/services', label: 'Services & Pricing' },
            { href: '/structural-burnout/briefing', label: 'Executive Briefing' },
            { href: '/structural-burnout/pitch', label: 'Investor Hub' },
            { href: '/books/', label: 'UNMASK Blueprint Series' },
          ].map((l) => (
            <li>
              <a href={l.href}
                 class="text-muted hover:text-light transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- URI -->
      <div>
        <p class="font-body text-xs font-700 uppercase tracking-widest text-muted mb-4">
          URI Formation
        </p>
        <ul class="space-y-2 text-sm">
          {[
            { href: '/uri/', label: 'Formation Overview' },
            { href: '/uri/#offerings', label: 'Formation Tiers' },
            { href: '/uri/#vetting', label: 'Speaking Request' },
          ].map((l) => (
            <li>
              <a href={l.href}
                 class="text-muted hover:text-light transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Entry -->
      <div>
        <p class="font-body text-xs font-700 uppercase tracking-widest text-muted mb-4">
          Quick Entry
        </p>
        <ul class="space-y-2 text-sm">
          {[
            { href: '/structural-burnout/nexus', label: 'Nexus Card' },
            { href: '/mogul-ops/', label: 'Mogul Ops Portal' },
            { href: '/structural-burnout/briefing', label: 'Request a Briefing' },
          ].map((l) => (
            <li>
              <a href={l.href}
                 class="text-muted hover:text-light transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-6 space-y-2">
          <a href="https://www.linkedin.com/in/nikkicates"
             target="_blank" rel="noopener"
             class="flex items-center gap-2 text-xs text-muted hover:text-light transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <div class="divider mt-10 mb-6"></div>

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <p class="text-muted text-xs">
        © {new Date().getFullYear()} Nikki Cates · Strategic Transformations · All rights reserved.
      </p>
      <p class="text-muted text-xs italic">
        Burnout is a design flaw. We fix the design.
      </p>
    </div>
  </div>
</footer>
